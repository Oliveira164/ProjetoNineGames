@model ProjetoNineGames.Models.Usuario
@{ ViewData["Title"] = "Meu Perfil"; }

<h2 style="margin-bottom:20px">Meu Perfil</h2>

@if (TempData["ok"] != null) { <div class="ng-alert ng-alert-ok">@TempData["ok"]</div> }

<div class="ng-form-card ng-perfil-card">
    <div style="margin-bottom:20px">
        <p style="font-size:14px;color:var(--ng-text-muted);margin-bottom:6px">Nome</p>
        <p style="font-size:16px;font-weight:600">@Model.Nome</p>
    </div>
    <div style="margin-bottom:20px">
        <p style="font-size:14px;color:var(--ng-text-muted);margin-bottom:6px">E-mail</p>
        <p style="font-size:16px">@Model.Email</p>
    </div>
    <div style="margin-bottom:24px">
        <p style="font-size:14px;color:var(--ng-text-muted);margin-bottom:6px">Role</p>
        @{
            var roleCls = Model.Role == "Admin" ? "ng-badge-blue"
                        : Model.Role == "Funcionario" ? "ng-badge-amber"
                        : "ng-badge-gray";
        }
        <span class="ng-badge @roleCls">@Model.Role</span>
    </div>

    <hr class="divider" />

    <h3 style="font-size:1rem;text-transform:uppercase;letter-spacing:.06em;margin-bottom:14px">
        Autenticação em 2 Etapas
    </h3>

    @if (Model.TwoFactorEnabled)
    {
        <div class="ng-twofa-box ng-twofa-on">
            🔒 O 2FA está <strong>ativado</strong>. Ao fazer login você precisará confirmar com o app.
        </div>
        <form asp-action="Desativar2Fa" method="post">
            @Html.AntiForgeryToken()
            <button class="btn-ng btn-ng-danger"
                    onclick="return confirm('Desativar o 2FA? Sua conta ficará menos protegida.')">
                Desativar 2FA
            </button>
        </form>
    }
    else
    {
        <div class="ng-twofa-box ng-twofa-off">
            🔓 O 2FA está <strong>desativado</strong>. Ative para proteger sua conta com o app NineGames.
        </div>
        <form asp-action="Ativar2Fa" method="post">
            @Html.AntiForgeryToken()
            <button class="btn-ng btn-ng-primary">Ativar 2FA</button>
        </form>
    }
</div>
