@{
    Layout = null;
    ViewData["Title"] = "Criar Conta — NineGames";
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="ng-auth-page">
        <div class="ng-auth-card">
            <div class="ng-auth-logo">
                <img src="~/images/Nine.png" alt="NineGames" asp-append-version="true" />
            </div>
            <h1 class="ng-auth-title">Crie Sua Conta</h1>
            <p class="ng-auth-sub">insira seus dados para se registrar</p>

            @if (ViewBag.Error != null)
            {
                <div class="ng-alert ng-alert-erro">@ViewBag.Error</div>
            }

            <form method="post" asp-action="Registrar" asp-controller="Usuario" id="form-registrar">
                @Html.AntiForgeryToken()

                <div class="ng-field-floating">
                    <input class="ng-input-floating" type="text" id="nome" name="nome"
                           placeholder=" " autocomplete="name" required autofocus maxlength="100" />
                    <label for="nome">Nome completo</label>
                </div>

                <div class="ng-field-floating">
                    <input class="ng-input-floating" type="email" id="email" name="email"
                           placeholder=" " autocomplete="email" required />
                    <label for="email">Email</label>
                </div>

                <div class="ng-field-floating has-toggle">
                    <input class="ng-input-floating" type="password" id="senha" name="senha"
                           placeholder=" " required minlength="6" />
                    <label for="senha">Senha</label>
                    <button type="button" class="ng-toggle-pwd" aria-label="Mostrar senha" data-target="senha">
                        <svg class="icon-eye" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7Z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                        <svg class="icon-eye-off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="display:none">
                            <path d="M3 3l18 18" />
                            <path d="M10.6 10.6a3 3 0 0 0 4.24 4.24" />
                            <path d="M9.9 4.24A10.94 10.94 0 0 1 12 4c7 0 11 7 11 7a17.3 17.3 0 0 1-3.1 3.94M6.1 6.1A17.4 17.4 0 0 0 1 11s4 7 11 7c1.46 0 2.84-.27 4.08-.74" />
                        </svg>
                    </button>
                </div>

                <div class="ng-field-floating has-toggle">
                    <input class="ng-input-floating" type="password" id="confirmarSenha" name="confirmarSenha"
                           placeholder=" " required minlength="6" />
                    <label for="confirmarSenha">Confirmar senha</label>
                    <button type="button" class="ng-toggle-pwd" aria-label="Mostrar senha" data-target="confirmarSenha">
                        <svg class="icon-eye" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7Z" />
                            <circle cx="12" cy="12" r="3" />
                        </svg>
                        <svg class="icon-eye-off" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="display:none">
                            <path d="M3 3l18 18" />
                            <path d="M10.6 10.6a3 3 0 0 0 4.24 4.24" />
                            <path d="M9.9 4.24A10.94 10.94 0 0 1 12 4c7 0 11 7 11 7a17.3 17.3 0 0 1-3.1 3.94M6.1 6.1A17.4 17.4 0 0 0 1 11s4 7 11 7c1.46 0 2.84-.27 4.08-.74" />
                        </svg>
                    </button>
                </div>
                <p class="ng-hint" id="hint-confirma" style="margin-top:-10px; margin-bottom:18px;"></p>

                <button type="submit" class="btn-ng btn-ng-primary btn-ng-full btn-ng-lg">
                    Criar conta
                </button>
            </form>

            <div class="ng-auth-actions-alt">
                <button type="button" class="btn-ng btn-ng-auth-alt btn-ng-full" onclick="history.back();">
                    &larr; Voltar
                </button>
            </div>
        </div>
    </div>

    <script>
        document.querySelectorAll('.ng-toggle-pwd').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var input = document.getElementById(btn.dataset.target);
                var showing = input.type === 'text';
                input.type = showing ? 'password' : 'text';
                btn.querySelector('.icon-eye').style.display = showing ? '' : 'none';
                btn.querySelector('.icon-eye-off').style.display = showing ? 'none' : '';
                btn.setAttribute('aria-label', showing ? 'Mostrar senha' : 'Ocultar senha');
            });
        });

        var senha = document.getElementById('senha');
        var confirmar = document.getElementById('confirmarSenha');
        var hint = document.getElementById('hint-confirma');

        function checarSenhas() {
            if (confirmar.value.length === 0) {
                hint.textContent = '';
                confirmar.style.borderColor = '';
                return;
            }
            if (senha.value !== confirmar.value) {
                hint.textContent = 'As senhas não coincidem';
                hint.style.color = '#f87171';
                confirmar.style.borderColor = '#f87171';
            } else {
                hint.textContent = 'As senhas coincidem';
                hint.style.color = '#4ade80';
                confirmar.style.borderColor = '#4ade80';
            }
        }

        senha.addEventListener('input', checarSenhas);
        confirmar.addEventListener('input', checarSenhas);

        document.getElementById('form-registrar').addEventListener('submit', function (e) {
            if (senha.value !== confirmar.value) {
                e.preventDefault();
                checarSenhas();
                confirmar.focus();
            }
        });
    </script>
</body>
</html>