@model ProjetoNineGames.Models.Usuario
@{ ViewData["Title"] = "Novo Usuário"; }

<h2 style="margin-bottom:20px">Novo Usuário</h2>

<div class="ng-form-card">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="ng-alert ng-alert-erro">
            @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            { <div>@e.ErrorMessage</div> }
        </div>
    }

    <form asp-action="Criar" method="post">
        @Html.AntiForgeryToken()

        <div class="ng-field">
            <label class="ng-label">Nome</label>
            <input class="ng-input" asp-for="Nome" required />
        </div>
        <div class="ng-field">
            <label class="ng-label">E-mail</label>
            <input class="ng-input" asp-for="Email" type="email" required />
        </div>
        <div class="ng-field">
            <label class="ng-label">Senha</label>
            <input class="ng-input" name="senha" type="password" required />
        </div>
        <div class="ng-field">
            <label class="ng-label">Role</label>
            <select class="ng-select" asp-for="Role" required>
                <option value="Cliente">Cliente</option>
                <option value="Funcionario">Funcionário</option>
                <option value="Admin">Admin</option>
            </select>
        </div>

        <div class="ng-form-actions">
            <button type="submit" class="btn-ng btn-ng-primary">Salvar</button>
            <a asp-action="Index" class="btn-ng btn-ng-ghost">Cancelar</a>
        </div>
    </form>
</div>
