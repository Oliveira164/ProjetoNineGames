@{
    ViewData["Title"] = "Configurar 2FA";
    string secret = ViewBag.Secret;
    string otpUri = ViewBag.OtpUri;
}

<style>
    .setup-card { max-width: 480px; background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 28px; }
    .setup-card h2 { font-size: 18px; margin: 0 0 6px; }
    .setup-card p  { font-size: 14px; color: #4b5563; margin: 0 0 20px; }
    .qr-wrap { background: #fff; border: 1px solid #e5e7eb; border-radius: 10px; padding: 16px; display: inline-block; margin-bottom: 20px; }
    .secret-box { background: #f3f4f6; border-radius: 8px; padding: 12px 16px; font-family: monospace; font-size: 15px; letter-spacing: 2px; color: #111827; word-break: break-all; margin-bottom: 20px; }
    .steps { list-style: none; padding: 0; margin: 0 0 20px; counter-reset: steps; }
    .steps li { counter-increment: steps; padding: 8px 0 8px 36px; position: relative; font-size: 14px; color: #374151; border-bottom: 1px solid #f1f5f9; }
    .steps li::before { content: counter(steps); position: absolute; left: 0; top: 8px; width: 24px; height: 24px; background: #7c3aed; color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 600; }
    .btn-concluir { display: inline-block; padding: 10px 24px; background: #7c3aed; color: #fff; border: none; border-radius: 8px; font-size: 14px; font-weight: 500; cursor: pointer; text-decoration: none; }
    .btn-concluir:hover { background: #6d28d9; }
    .alert-info { background:#eff6ff; border:1px solid #bfdbfe; color:#1e40af; padding:10px 14px; border-radius:8px; margin-bottom:16px; font-size:13px; }
</style>

<h2 style="margin-bottom:20px">Configurar 2FA</h2>

<div class="setup-card">
    <div class="alert-info">
        ✅ Seu secret foi gerado e salvo. Agora configure o app para completar a ativação.
    </div>

    <h2>🔐 Configure o App</h2>
    <p>Escaneie o QR Code com o app NineGames (ou outro app TOTP).</p>

    <!-- QR Code gerado via Google Charts API -->
    <div class="qr-wrap">
        <img src="https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=@Uri.EscapeDataString(otpUri)"
             alt="QR Code 2FA" width="200" height="200" />
    </div>

    <p style="margin-bottom:8px;font-size:13px;color:#6b7280">
        Ou insira a chave manualmente no app:
    </p>
    <div class="secret-box">@secret</div>

    <ol class="steps">
        <li>Abra o app <strong>NineGames</strong> no celular</li>
        <li>Acesse <strong>Configurações → Adicionar conta</strong></li>
        <li>Escaneie o QR Code ou insira a chave acima</li>
        <li>O app passará a gerar códigos de 6 dígitos a cada 30 segundos</li>
        <li>No próximo login, informe esse código na tela de verificação</li>
    </ol>

    <a asp-action="Perfil" class="btn-concluir">Concluir configuração</a>
</div>
