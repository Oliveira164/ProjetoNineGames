@model List<ProjetoNineGames.Models.Usuario>
@{
    ViewData["Title"] = "Usuários";
}

<style>
    .tbl { width: 100%; border-collapse: collapse; font-size: 14px; }
    .tbl th, .tbl td { padding: 10px 12px; border-bottom: 1px solid #e5e7eb; text-align: left;}
    .tbl thead th { background: #f9fafb; font-weight: 600; border-bottom: 2px solid #d1d5db; }
    tbody {background: #f9fafb;}
    .badge { display:inline-block; padding:2px 9px; border-radius:12px; font-size:11px; font-weight:500; }
    .badge-admin  { background:#ede9fe; color:#5b21b6; }
    .badge-func   { background:#dbeafe; color:#1e40af; }
    .badge-cli    { background:#d1fae5; color:#065f46; }
    .badge-ativo  { background:#dcfce7; color:#166534; }
    .badge-inativo{ background:#fee2e2; color:#991b1b; }
    .badge-2fa    { background:#fef3c7; color:#92400e; }
    .acoes { display: flex; gap: 6px; }
    .btn-sm { padding: 5px 10px; border-radius: 5px; font-size: 12px; cursor: pointer; border: 1px solid; }
    .btn-ativar   { border-color:#6ee7b7; color:#065f46; background:#ecfdf5; }
    .btn-desativar{ border-color:#fca5a5; color:#991b1b; background:#fef2f2; }
    .header-bar   { display:flex; align-items:center; gap:12px; margin-bottom:16px; }
    .header-bar h2 { margin:0; flex:1; }
    .btn-novo { padding:8px 16px; background:#F96300; color:#fff; border:none; border-radius:7px; font-size:14px; font-weight:500; cursor:pointer; text-decoration:none; }
    .alert-ok   { background:#ecfdf5; border:1px solid #6ee7b7; color:#065f46; padding:10px 14px; border-radius:8px; margin-bottom:14px; }
</style>

<div class="header-bar">
    <h2>Usuários</h2>
    <a asp-action="Criar" class="btn-novo">+ Novo Usuário</a>
</div>

@if (TempData["ok"] != null) { <div class="alert-ok">@TempData["ok"]</div> }

<table class="tbl">
    <thead>
        <tr>
            <th>#</th>
            <th>Nome</th>
            <th>E-mail</th>
            <th>Role</th>
            <th>Status</th>
            <th>2FA</th>
            <th>Criado em</th>
            <th>Ações</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var u in Model)
        {
            <tr>
                <td>@u.Id</td>
                <td>@u.Nome</td>
                <td style="color:#6b7280">@u.Email</td>
                <td>
                    <span class="badge @(u.Role == "Admin" ? "badge-admin" : u.Role == "Funcionario" ? "badge-func" : "badge-cli")">
                        @u.Role
                    </span>
                </td>
                <td>
                    <span class="badge @(u.Ativo == 1 ? "badge-ativo" : "badge-inativo")">
                        @(u.Ativo == 1 ? "Ativo" : "Inativo")
                    </span>
                </td>
                <td>
                    @if (u.TwoFactorEnabled)
                    { <span class="badge badge-2fa">🔐 Ativo</span> }
                    else
                    { <span style="color:#9ca3af;font-size:12px">—</span> }
                </td>
                <td style="color:#6b7280;font-size:12px">@u.CriadoEm.ToString("dd/MM/yyyy")</td>
                <td>
                    <div class="acoes">
                        @if (u.Ativo == 1)
                        {
                            <form asp-action="AlterarAtivo" method="post"
                                  onsubmit="return confirm('Desativar @u.Nome?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id"    value="@u.Id" />
                                <input type="hidden" name="ativo" value="0" />
                                <button class="btn-sm btn-desativar">Desativar</button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="AlterarAtivo" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id"    value="@u.Id" />
                                <input type="hidden" name="ativo" value="1" />
                                <button class="btn-sm btn-ativar">Ativar</button>
                            </form>
                        }
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
