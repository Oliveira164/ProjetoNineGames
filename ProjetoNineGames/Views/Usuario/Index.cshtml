@model List<ProjetoNineGames.Models.Usuario>
@{ ViewData["Title"] = "Usuários"; }

<div class="ng-section-header">
    <h2>Usuários</h2>
    <a asp-action="Criar" class="btn-ng btn-ng-primary">+ Novo Usuário</a>
</div>

@if (TempData["ok"] != null) { <div class="ng-alert ng-alert-ok">@TempData["ok"]</div> }

<div class="ng-card" style="padding:0;overflow:hidden">
    <table class="ng-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Nome</th>
                <th>E-mail</th>
                <th>Role</th>
                <th>Status</th>
                <th>2FA</th>
                <th>Criado em</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model)
            {
                <tr>
                    <td class="text-muted">@u.Id</td>
                    <td style="font-weight:600">@u.Nome</td>
                    <td class="text-muted">@u.Email</td>
                    <td>
                        @{
                            var roleCls = u.Role == "Admin" ? "ng-badge-blue"
                                        : u.Role == "Funcionario" ? "ng-badge-amber"
                                        : "ng-badge-gray";
                        }
                        <span class="ng-badge @roleCls">@u.Role</span>
                    </td>
                    <td>
                        <span class="ng-badge @(u.Ativo == 1 ? "ng-badge-green" : "ng-badge-red")">
                            @(u.Ativo == 1 ? "Ativo" : "Inativo")
                        </span>
                    </td>
                    <td>
                        @if (u.TwoFactorEnabled)
                        { <span class="ng-badge ng-badge-orange"> Ativo</span> }
                        else { <span class="text-muted">—</span> }
                    </td>
                    <td class="text-muted" style="font-size:12px">@u.CriadoEm.ToString("dd/MM/yyyy")</td>
                    <td>
                        @if (u.Ativo == 1)
                        {
                            <form asp-action="AlterarAtivo" method="post"
                                  onsubmit="return confirm('Desativar @u.Nome?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id"    value="@u.Id" />
                                <input type="hidden" name="ativo" value="0" />
                                <button class="btn-ng btn-ng-danger btn-ng-sm">Desativar</button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="AlterarAtivo" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id"    value="@u.Id" />
                                <input type="hidden" name="ativo" value="1" />
                                <button class="btn-ng btn-ng-ghost btn-ng-sm">Ativar</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
