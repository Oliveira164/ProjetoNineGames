@using ProjetoNineGames.Autenticacao
@{
    var isLogged = Context.Session.GetInt32(SessionKeys.UserId).HasValue;
    var role     = Context.Session.GetString(SessionKeys.UserRole)     ?? "";
    var userName = Context.Session.GetString(SessionKeys.UserName)     ?? "";
    var fotoUrl = Context.Session.GetString("UserPhotoUrl");
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] — NineGames</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: system-ui, Segoe UI, Roboto, Arial, sans-serif;
            background: #0d0d0d;
            color: #f0f0f0;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* ════════════════════════════════════════════════════
           NAVBAR DESKTOP
        ════════════════════════════════════════════════════ */
        .topnav {
            display: flex;
            align-items: center;
            gap: 2px;
            padding: 0 20px;
            background: rgba(13,13,13,.97);
            height: 54px;
            position: sticky;
            top: 0;
            z-index: 200;
            border-bottom: 1px solid #1f1f1f;
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
        }

        .topnav-brand {
            display: flex;
            align-items: center;
            text-decoration: none;
            margin-right: 14px;
            flex-shrink: 0;
        }

        .topnav-brand img { height: 38px; width: auto; }

        /* Links de navegação desktop */
        .nav-links {
            display: flex;
            align-items: center;
            gap: 2px;
            flex: 1;
        }

        .nav-links a {
            color: #a1a1aa;
            text-decoration: none;
            padding: 6px 10px;
            border-radius: 6px;
            font-size: 13px;
            white-space: nowrap;
            transition: background .15s, color .15s;
        }

        .nav-links a:hover { background: rgba(249,99,0,.12); color: #F96300; }

        /* Área direita: usuário + sair */
        .nav-right {
            display: flex;
            align-items: center;
            gap: 8px;
            flex-shrink: 0;
            margin-left: auto;
        }

        /* Avatar + nome na navbar */
        .topnav-user {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #a1a1aa;
            font-size: 13px;
            text-decoration: none;
            padding: 4px 8px;
            border-radius: 8px;
            transition: background .15s;
            white-space: nowrap;
        }

        .topnav-user:hover { background: rgba(249,99,0,.12); color: #F96300; }

        .nav-avatar {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            border: 1.5px solid #3a3a3a;
            background: #222;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            flex-shrink: 0;
        }

        .nav-avatar img { width: 100%; height: 100%; object-fit: cover; }

        /* Botão sair */
        .btn-sair {
            background: none;
            border: 1px solid #3a3a3a;
            color: #a1a1aa;
            border-radius: 6px;
            padding: 5px 12px;
            font-size: 13px;
            cursor: pointer;
            white-space: nowrap;
            transition: border-color .15s, color .15s;
        }

        .btn-sair:hover { border-color: #F96300; color: #F96300; }

        /* Botão hamburguer — oculto no desktop */
        .btn-hamburger {
            display: none;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 5px;
            width: 36px;
            height: 36px;
            background: transparent;
            border: 1px solid #2a2a2a;
            border-radius: 8px;
            cursor: pointer;
            margin-left: auto;
            flex-shrink: 0;
            padding: 0;
        }

        .btn-hamburger span {
            display: block;
            width: 18px;
            height: 1.5px;
            background: #a1a1aa;
            border-radius: 2px;
            transition: transform .25s, opacity .25s;
        }

        /* Animação hamburguer → X */
        .btn-hamburger.aberto span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
        .btn-hamburger.aberto span:nth-child(2) { opacity: 0; }
        .btn-hamburger.aberto span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

        /* ════════════════════════════════════════════════════
           MENU MOBILE (drawer)
        ════════════════════════════════════════════════════ */
        .mobile-menu {
            display: none;         /* oculto no desktop */
            position: fixed;
            top: 54px;
            left: 0;
            right: 0;
            bottom: 0;
            z-index: 199;
            pointer-events: none;
        }

        /* Overlay escuro atrás do drawer */
        .mobile-menu-overlay {
            position: absolute;
            inset: 0;
            background: rgba(0,0,0,.6);
            opacity: 0;
            transition: opacity .25s;
        }

        /* Painel lateral */
        .mobile-menu-panel {
            position: absolute;
            top: 0;
            right: 0;
            width: min(280px, 85vw);
            height: 100%;
            background: #111;
            border-left: 1px solid #1f1f1f;
            transform: translateX(100%);
            transition: transform .25s cubic-bezier(.4,0,.2,1);
            overflow-y: auto;
            padding: 16px 0 32px;
            display: flex;
            flex-direction: column;
        }

        /* Aberto */
        .mobile-menu.aberto {
            pointer-events: all;
        }

        .mobile-menu.aberto .mobile-menu-overlay { opacity: 1; }
        .mobile-menu.aberto .mobile-menu-panel   { transform: translateX(0); }

        /* Seção de perfil no topo do drawer */
        .mob-perfil {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 20px 16px;
            border-bottom: 1px solid #1f1f1f;
            margin-bottom: 8px;
            text-decoration: none;
        }

        .mob-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            border: 1.5px solid #F96300;
            background: #222;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            flex-shrink: 0;
        }

        .mob-avatar img { width: 100%; height: 100%; object-fit: cover; }

        .mob-nome { font-size: 14px; font-weight: 600; color: #f0f0f0; }
        .mob-email-link { font-size: 12px; color: #a1a1aa; }

        /* Links do drawer */
        .mob-link {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 11px 20px;
            font-size: 14px;
            color: #a1a1aa;
            text-decoration: none;
            transition: background .15s, color .15s;
            border-left: 2px solid transparent;
        }

        .mob-link:hover { background: rgba(249,99,0,.1); color: #F96300; border-left-color: #F96300; }

        .mob-link .mob-icon { font-size: 17px; flex-shrink: 0; }

        /* Separador de seção no drawer */
        .mob-sep {
            font-size: 10px;
            font-weight: 700;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: #555;
            padding: 14px 20px 6px;
        }

        /* Botão sair no drawer */
        .mob-sair-wrap {
            margin-top: auto;
            padding: 16px 20px 0;
            border-top: 1px solid #1f1f1f;
        }

        .mob-sair-btn {
            width: 100%;
            padding: 10px;
            background: transparent;
            border: 1px solid #3a3a3a;
            color: #a1a1aa;
            border-radius: 8px;
            font-size: 14px;
            cursor: pointer;
            transition: border-color .15s, color .15s;
        }

        .mob-sair-btn:hover { border-color: #F96300; color: #F96300; }

        /* ════════════════════════════════════════════════════
           MAIN
        ════════════════════════════════════════════════════ */
        main.container {
            flex: 1;
            padding: 28px 24px;
            max-width: 1240px;
            margin: 0 auto;
            width: 100%;
        }

        /* ════════════════════════════════════════════════════
           FOOTER
        ════════════════════════════════════════════════════ */
        .site-footer {
            background: #111113;
            border-top: 1px solid #1f1f23;
            padding: 48px 24px 24px;
            margin-top: auto;
        }

        .footer-inner { max-width: 1240px; margin: 0 auto; }

        .footer-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 36px;
            flex-wrap: wrap;
            gap: 16px;
        }

        .footer-brand {
            font-size: 20px;
            font-weight: 900;
            color: #F96300;
            letter-spacing: -.5px;
            text-decoration: none;
        }

        .footer-cols {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 32px;
            margin-bottom: 40px;
        }

        .footer-col h4 {
            font-size: 12px;
            font-weight: 700;
            color: #fff;
            letter-spacing: 1.2px;
            text-transform: uppercase;
            margin-bottom: 16px;
        }

        .footer-col ul { list-style: none; }
        .footer-col ul li { margin-bottom: 10px; }
        .footer-col ul li a { font-size: 13px; color: #a1a1aa; text-decoration: none; transition: color .2s; }
        .footer-col ul li a:hover { color: #F96300; }

        .footer-copy {
            border-top: 1px solid #1f1f23;
            padding-top: 24px;
            text-align: center;
            font-size: 12px;
            color: #71717a;
            line-height: 1.6;
        }

        .legal-links {
            margin-top: 12px;
            display: flex;
            justify-content: center;
            gap: 16px;
            flex-wrap: wrap;
        }

        .legal-links a { color: #a1a1aa; text-decoration: none; transition: color .2s; }
        .legal-links a:hover { color: #F96300; }

        /* ════════════════════════════════════════════════════
           RESPONSIVO — ponto de corte 860px
        ════════════════════════════════════════════════════ */
        @@media (max-width: 860px) {

            /* Oculta links e área direita do desktop */
            .nav-links  { display: none; }
            .nav-right  { display: none; }

            /* Exibe o botão hamburguer */
            .btn-hamburger { display: flex; }

            /* Ativa o menu mobile */
            .mobile-menu { display: block; }

            main.container { padding: 20px 16px; }

            .site-footer { padding: 32px 16px 20px; }
            .footer-top  { justify-content: center; }
            .footer-brand { text-align: center; width: 100%; }
            .footer-cols { grid-template-columns: 1fr 1fr; gap: 24px; }
        }

        @@media (max-width: 480px) {
            .footer-cols { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <!-- ══ Navbar ══════════════════════════════════════════════ -->
    <header>
        <nav class="topnav" role="navigation" aria-label="Navegação principal">

            <a class="topnav-brand" asp-controller="Home" asp-action="Index" aria-label="NineGames - Página inicial">
                <img src="~/images/Nine.png" alt="NineGames" asp-append-version="true" />
            </a>

            <!-- Links desktop -->
            <div class="nav-links">
                <a asp-controller="Home"     asp-action="Index">Home</a>
                <a asp-controller="Jogo"     asp-action="Index">Vitrine</a>
                <a asp-controller="Carrinho" asp-action="Index">Carrinho</a>

                @if (isLogged)
                {
                    <a asp-controller="Biblioteca" asp-action="MinhaBiblioteca">Biblioteca</a>
                    <a asp-controller="Biblioteca" asp-action="Wishlist">Wishlist</a>

                    @if (role is "Admin" or "Funcionario")
                    {
                        <a asp-controller="Dashboard" asp-action="Index">Dashboard</a>
                        <a asp-controller="Jogo"      asp-action="Gerenciar">Gerenciar Jogos</a>
                        <a asp-controller="Categoria" asp-action="Index">Categorias</a>
                    }
                    @if (role == "Admin")
                    {
                        <a asp-controller="Usuario" asp-action="Index">Usuários</a>
                    }
                }
            </div>

            <!-- Área direita desktop -->
            <div class="nav-right">
                @if (isLogged)
                {
                    <a asp-controller="Usuario" asp-action="Perfil" class="topnav-user">
                        <div class="nav-avatar">
                            @if (!string.IsNullOrEmpty(fotoUrl))
                            { <img src="~/@fotoUrl" alt="Foto de @userName" /> }
                            else
                            { <span>👤</span> }
                        </div>
                        @userName
                    </a>
                    <form asp-controller="Auth" asp-action="Logout" method="post" style="display:inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn-sair">Sair</button>
                    </form>
                }
                else
                {
                    <a asp-controller="Auth" asp-action="Login"
                       style="color:#a1a1aa;font-size:13px;padding:6px 10px;text-decoration:none;border-radius:6px;transition:background .15s">
                        Entrar
                    </a>
                }
            </div>

            <!-- Botão hamburguer (só no mobile) -->
            <button class="btn-hamburger" id="btnHamburger"
                    aria-label="Abrir menu" aria-expanded="false" aria-controls="mobileMenu">
                <span></span>
                <span></span>
                <span></span>
            </button>

        </nav>
    </header>

    <!-- ══ Menu Mobile ═════════════════════════════════════════ -->
    <div class="mobile-menu" id="mobileMenu" aria-hidden="true">
        <div class="mobile-menu-overlay" id="menuOverlay"></div>
        <div class="mobile-menu-panel" role="dialog" aria-label="Menu de navegação">

            @if (isLogged)
            {
                <!-- Perfil no topo do drawer -->
                <a asp-controller="Usuario" asp-action="Perfil" class="mob-perfil" id="mobPerfilLink">
                    <div class="mob-avatar">
                        @if (!string.IsNullOrEmpty(fotoUrl))
                        { <img src="~/@fotoUrl" alt="Avatar" /> }
                        else { <span>👤</span> }
                    </div>
                    <div>
                        <div class="mob-nome">@userName</div>
                        <div class="mob-email-link">Ver meu perfil →</div>
                    </div>
                </a>
            }

            <!-- Links principais -->
            <div class="mob-sep">Navegação</div>
            <a class="mob-link" asp-controller="Home"     asp-action="Index">
                 Home
            </a>
            <a class="mob-link" asp-controller="Jogo"     asp-action="Index">
                 Vitrine
            </a>
            <a class="mob-link" asp-controller="Carrinho" asp-action="Index">
                 Carrinho
            </a>

            @if (isLogged)
            {
                <div class="mob-sep">Minha Conta</div>
                <a class="mob-link" asp-controller="Biblioteca" asp-action="MinhaBiblioteca">
                     Biblioteca
                </a>
                <a class="mob-link" asp-controller="Biblioteca" asp-action="Wishlist">
                     Wishlist
                </a>
                <a class="mob-link" asp-controller="Usuario" asp-action="Perfil" asp-route-aba="meus-pedidos">
                     Meus Pedidos
                </a>

                @if (role is "Admin" or "Funcionario")
                {
                    <div class="mob-sep">Administração</div>
                    <a class="mob-link" asp-controller="Dashboard" asp-action="Index">
                         Dashboard
                    </a>
                    <a class="mob-link" asp-controller="Jogo" asp-action="Gerenciar">
                         Gerenciar Jogos
                    </a>
                    <a class="mob-link" asp-controller="Categoria" asp-action="Index">
                         Categorias
                    </a>
                }
                @if (role == "Admin")
                {
                    <a class="mob-link" asp-controller="Usuario" asp-action="Index">
                         Usuários
                    </a>
                }

                <!-- Botão sair no drawer -->
                <div class="mob-sair-wrap">
                    <form asp-controller="Auth" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="mob-sair-btn">Sair da conta</button>
                    </form>
                </div>
            }
            else
            {
                <div class="mob-sep">Conta</div>
                <a class="mob-link" asp-controller="Auth" asp-action="Login">
                     Entrar
                </a>
                <a class="mob-link" asp-controller="Usuario" asp-action="Registrar">
                     Criar conta grátis
                </a>
            }

        </div>
    </div>

    <!-- ══ Conteúdo ═══════════════════════════════════════════ -->
    <main class="container">
        @RenderBody()
    </main>

    <!-- ══ Footer ═════════════════════════════════════════════ -->
    <footer class="site-footer">
        <div class="footer-inner">
            <div class="footer-top">
                <a asp-controller="Home" asp-action="Index" class="footer-brand">NineGames</a>
            </div>

            <div class="footer-cols">
                <div class="footer-col">
                    <h4>Loja</h4>
                    <ul>
                        <li><a asp-controller="Jogo" asp-action="Index">Explorar Vitrine</a></li>
                        <li><a asp-controller="Jogo" asp-action="Index" asp-route-categoria="RPG">Jogos de RPG</a></li>
                        <li><a asp-controller="Jogo" asp-action="Index" asp-route-categoria="Ação">Jogos de Ação</a></li>
                        <li><a asp-controller="Jogo" asp-action="Index" asp-route-categoria="Soulslike">Soulslike</a></li>
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Minha Conta</h4>
                    <ul>
                        @if (isLogged)
                        {
                            <li><a asp-controller="Usuario"   asp-action="Perfil">Meu Perfil</a></li>
                            <li><a asp-controller="Biblioteca" asp-action="MinhaBiblioteca">Minha Biblioteca</a></li>
                            <li><a asp-controller="Biblioteca" asp-action="Wishlist">Lista de Desejos</a></li>
                            <li><a asp-controller="Carrinho"  asp-action="Index">Carrinho</a></li>
                        }
                        else
                        {
                            <li><a asp-controller="Auth"    asp-action="Login">Fazer Login</a></li>
                            <li><a asp-controller="Usuario" asp-action="Registrar">Criar Conta Grátis</a></li>
                        }
                    </ul>
                </div>
                <div class="footer-col">
                    <h4>Atendimento</h4>
                    <ul>
                        <li><a href="https://w.app/6rhj1e" target="_blank" rel="noopener">Central de Ajuda</a></li>
                        <li><a href="https://w.app/6rhj1e" target="_blank" rel="noopener">Contato e Suporte</a></li>
                    </ul>
                </div>
            </div>

            <div class="footer-copy">
                <p>© @DateTime.Now.Year NineGames. Todos os direitos reservados.</p>
                <p style="max-width:640px;margin:8px auto 0">
                    Todo o conteúdo deste site é de propriedade exclusiva da NineGames
                    e protegido pelas leis de direitos autorais aplicáveis.
                </p>
                <div class="legal-links">
                    <a asp-controller="Home" asp-action="Termos">Termos de Uso</a>
                    <span>•</span>
                    <a asp-controller="Home" asp-action="Privacidade">Política de Privacidade</a>
                </div>
            </div>
        </div>
    </footer>

    <button id="btnVoltarTopo" onclick="voltarAoTopo()" title="Voltar ao topo">
        ↑
    </button>

    <!-- ══ Script do menu hamburguer ══════════════════════════ -->
    <script>
        (function () {
            const btn     = document.getElementById('btnHamburger');
            const menu    = document.getElementById('mobileMenu');
            const overlay = document.getElementById('menuOverlay');
            if (!btn || !menu) return;

            function abrir() {
                btn.classList.add('aberto');
                menu.classList.add('aberto');
                menu.setAttribute('aria-hidden', 'false');
                btn.setAttribute('aria-expanded', 'true');
                document.body.style.overflow = 'hidden';
            }

            function fechar() {
                btn.classList.remove('aberto');
                menu.classList.remove('aberto');
                menu.setAttribute('aria-hidden', 'true');
                btn.setAttribute('aria-expanded', 'false');
                document.body.style.overflow = '';
            }

            btn.addEventListener('click', () =>
                menu.classList.contains('aberto') ? fechar() : abrir()
            );

            // Fecha ao clicar no overlay
            overlay.addEventListener('click', fechar);

            // Fecha ao clicar em qualquer link do drawer
            menu.querySelectorAll('a, .mob-sair-btn').forEach(el =>
                el.addEventListener('click', fechar)
            );

            // Fecha com Esc
            document.addEventListener('keydown', e => {
                if (e.key === 'Escape' && menu.classList.contains('aberto')) fechar();
            });

            // Fecha drawer ao redimensionar para desktop
            window.addEventListener('resize', () => {
                if (window.innerWidth > 860) fechar();
            });
        })();

            // Seleciona o botão
        let btnTopo = document.getElementById("btnVoltarTopo");

        // Fica "escutando" o scroll da tela
        window.onscroll = function() {
            // Se desceu mais de 300 pixels, mostra o botão
            if (document.body.scrollTop > 300 || document.documentElement.scrollTop > 300) {
                btnTopo.classList.add("mostrar");
                btnTopo.style.display = "flex"; // Garante que ele apareça
            } else {
                btnTopo.classList.remove("mostrar");
            }
        };

        // Função executada ao clicar no botão
        function voltarAoTopo() {
            window.scrollTo({
                top: 0,
                behavior: 'smooth' // Faz a rolagem ser suave e elegante
            });
        }
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
