@model List<ProjetoNineGames.Models.Jogo>
@{ ViewData["Title"] = "Minha Biblioteca"; }

<h2 style="margin-bottom:4px">Minha Biblioteca</h2>
<p class="text-muted" style="font-size:14px;margin-bottom:22px">Seus jogos adquiridos</p>

@if (ViewBag.Ok != null) { <div class="ng-alert ng-alert-ok">@ViewBag.Ok</div> }

@if (!Model.Any())
{
    <div class="ng-vazio">
        <div class="icon">📦</div>
        <p>Você ainda não tem jogos.</p>
        <a asp-controller="Jogo" asp-action="Index" class="btn-ng btn-ng-primary">Explorar a vitrine</a>
    </div>
}
else
{
    <div class="ng-bib-grid">
        @foreach (var j in Model)
        {
            <div class="ng-bib-card">
                <div class="ng-bib-thumb">
                    @if (!string.IsNullOrWhiteSpace(j.ImagemUrl))
                    { <img src="~/@j.ImagemUrl" alt="@j.Titulo" /> }
                    else { <span>🎮</span> }
                </div>
                <div class="ng-bib-body">
                    <p class="ng-bib-titulo">@j.Titulo</p>
                    @if (!string.IsNullOrWhiteSpace(j.Categoria))
                    { <span class="ng-badge ng-badge-orange">@j.Categoria</span> }
                </div>
            </div>
        }
    </div>
}
