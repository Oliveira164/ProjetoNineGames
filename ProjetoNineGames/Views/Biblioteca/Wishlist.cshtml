@model List<ProjetoNineGames.Models.Jogo>
@{ ViewData["Title"] = "Lista de Desejos"; }

<h2 style="margin-bottom:4px">Lista de Desejos</h2>
<p class="text-muted" style="font-size:14px;margin-bottom:22px">Jogos que você quer comprar futuramente</p>

@if (!Model.Any())
{
    <div class="ng-vazio">
        <div class="icon">❤️</div>
        <p>Sua lista de desejos está vazia.</p>
        <a asp-controller="Jogo" asp-action="Index" class="btn-ng btn-ng-primary">Explorar jogos</a>
    </div>
}
else
{
    <div class="ng-bib-grid">
        @foreach (var j in Model)
        {
            <div class="ng-bib-card">
                <div class="ng-bib-thumb">
                    @if (!string.IsNullOrWhiteSpace(j.ImagemUrl))
                    { <img src="~/@j.ImagemUrl" alt="@j.Titulo" /> }
                    else { <span>🎮</span> }
                </div>
                <div class="ng-bib-body">
                    <p class="ng-bib-titulo">@j.Titulo</p>
                    <p class="ng-bib-preco">
                        @(j.Preco == 0 ? "Gratuito" : "R$ " + j.Preco.ToString("N2"))
                    </p>
                    <div class="ng-bib-acoes">
                        <form asp-controller="Carrinho" asp-action="Adicionar" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="jogoId" value="@j.Id" />
                            <button class="btn-ng btn-ng-primary btn-ng-sm btn-ng-full">+ Carrinho</button>
                        </form>
                        <form asp-controller="Biblioteca" asp-action="RemoverWishlist" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="jogoId" value="@j.Id" />
                            <button class="btn-ng btn-ng-danger btn-ng-sm btn-ng-full"
                                    onclick="return confirm('Remover da wishlist?')">✕ Remover</button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
