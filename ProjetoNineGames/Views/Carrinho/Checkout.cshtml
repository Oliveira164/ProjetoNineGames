@model ProjetoNineGames.Models.Pagamento
@{
	ViewData["Title"] = "Pagamento";
}

<style>
	/* ── Layout checkout ───────────────────────────────────────── */
	.checkout-wrap {
		display: grid;
		grid-template-columns: 1fr 340px;
		gap: 24px;
		align-items: start;
	}

	/* ── Tabs de método ────────────────────────────────────────── */
	.metodos {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 10px;
		margin-bottom: 28px;
	}

	.metodo-btn {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 6px;
		padding: 14px 10px;
		background: var(--ng-bg-input);
		border: 1.5px solid var(--ng-border);
		border-radius: 12px;
		cursor: pointer;
		transition: border-color var(--ng-tr), background var(--ng-tr);
		font-family: var(--ng-font-body);
		color: var(--ng-text-muted);
		font-size: 13px;
		font-weight: 500;
	}

		.metodo-btn .icon {
			font-size: 22px;
		}

		.metodo-btn:hover {
			border-color: var(--ng-border-o);
			color: var(--ng-text);
		}

		.metodo-btn.ativo {
			border-color: var(--ng-orange);
			background: var(--ng-orange-subtle);
			color: var(--ng-orange);
		}

	/* ── Painéis de forma ──────────────────────────────────────── */
	.painel {
		display: none;
	}

		.painel.visivel {
			display: block;
		}

	/* ── Card visual ───────────────────────────────────────────── */
	.card-visual {
		background: linear-gradient(135deg, #1a1a1a 0%, #2a1500 100%);
		border: 1px solid var(--ng-border-o);
		border-radius: 16px;
		padding: 22px 24px;
		margin-bottom: 22px;
		position: relative;
		overflow: hidden;
		min-height: 160px;
	}

		.card-visual::before {
			content: '';
			position: absolute;
			top: -40px;
			right: -40px;
			width: 160px;
			height: 160px;
			border-radius: 50%;
			background: rgba(249,99,0,.12);
		}

	.card-visual-chip {
		width: 36px;
		height: 26px;
		background: linear-gradient(135deg, #d4a843, #f0c060);
		border-radius: 5px;
		margin-bottom: 18px;
	}

	.card-visual-numero {
		font-family: 'Courier New', monospace;
		font-size: 18px;
		font-weight: 700;
		letter-spacing: 3px;
		color: var(--ng-text);
		margin-bottom: 14px;
	}

	.card-visual-footer {
		display: flex;
		justify-content: space-between;
		font-size: 12px;
		color: var(--ng-text-muted);
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	.card-visual-nome {
		font-size: 14px;
		font-weight: 600;
		color: var(--ng-text);
	}

	/* ── Bandeira automática ───────────────────────────────────── */
	.bandeira {
		position: absolute;
		top: 20px;
		right: 20px;
		font-size: 28px;
	}

	/* ── Pix ───────────────────────────────────────────────────── */
	.pix-box {
		background: var(--ng-bg-input);
		border: 1px solid var(--ng-border);
		border-radius: 12px;
		padding: 24px;
		text-align: center;
	}

	.pix-qr {
		display: inline-block;
		background: #fff;
		border-radius: 10px;
		padding: 12px;
		margin-bottom: 16px;
	}

		.pix-qr img {
			display: block;
		}

	.pix-chave-wrap {
		display: flex;
		align-items: center;
		gap: 8px;
		background: var(--ng-bg-card);
		border: 1px solid var(--ng-border);
		border-radius: 8px;
		padding: 10px 14px;
		margin-top: 10px;
	}

	.pix-chave {
		flex: 1;
		font-family: monospace;
		font-size: 13px;
		color: var(--ng-orange);
		word-break: break-all;
		text-align: left;
	}

	.btn-copiar-pix {
		background: transparent;
		border: none;
		color: var(--ng-text-muted);
		cursor: pointer;
		font-size: 16px;
		padding: 2px 6px;
		transition: color var(--ng-tr);
	}

		.btn-copiar-pix:hover {
			color: var(--ng-orange);
		}

	/* ── Campos do formulário ──────────────────────────────────── */
	.campo-grid-2 {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 14px;
	}

	.campo-grid-3 {
		display: grid;
		grid-template-columns: 2fr 1fr 1fr;
		gap: 14px;
	}

	/* ── Resumo lateral ────────────────────────────────────────── */
	.resumo-item {
		display: flex;
		justify-content: space-between;
		font-size: 13px;
		color: var(--ng-text-muted);
		padding: 6px 0;
		border-bottom: 1px solid rgba(255,255,255,.04);
	}

		.resumo-item:last-of-type {
			border-bottom: none;
		}

	/* ── Segurança ─────────────────────────────────────────────── */
	.seguranca {
		display: flex;
		align-items: center;
		gap: 8px;
		font-size: 12px;
		color: var(--ng-text-dim);
		margin-top: 14px;
		justify-content: center;
	}

	@@media (max-width: 900px) {
		.checkout-wrap

	{
		grid-template-columns: 1fr;
	}

	.metodos {
		grid-template-columns: repeat(3, 1fr);
	}

	.campo-grid-3 {
		grid-template-columns: 1fr 1fr;
	}

	}</style>

<h2 style="margin-bottom:6px">Pagamento</h2>
<p class="text-muted" style="font-size:14px;margin-bottom:24px">
	Escolha a forma de pagamento e preencha os dados para finalizar.
</p>

@if (TempData["erro"] != null)
{
	<div class="ng-alert ng-alert-erro" style="margin-bottom:20px">@TempData["erro"]</div>
}

<form asp-action="Checkout" method="post" id="formCheckout">
	@Html.AntiForgeryToken()
	<input type="hidden" name="FormaPagamento" id="inputFormaPagamento" value="@Model.FormaPagamento" />

	<div class="checkout-wrap">

		<!-- ── Coluna esquerda: método + dados ─────────────────── -->
		<div>

			<!-- Tabs de método -->
			<div class="metodos">
				<button type="button" class="metodo-btn @(Model.FormaPagamento == "Crédito" ? "ativo" : "")"
						onclick="selecionarMetodo('Crédito', this)">
					<span class="icon">💳</span>
					Crédito
				</button>
				<button type="button" class="metodo-btn @(Model.FormaPagamento == "Crédito" ? "ativo" : "")"
						onclick="selecionarMetodo('Débito', this)">
					<span class="icon">🏦</span>
					Débito
				</button>
				<button type="button" class="metodo-btn @(Model.FormaPagamento == "Débito" ? "ativo" : "")"
						onclick="selecionarMetodo('Pix', this)">
					<span class="icon">⚡</span>
					Pix
				</button>
			</div>

			@if (!ViewData.ModelState.IsValid)
			{
				<div class="ng-alert ng-alert-erro" style="margin-bottom:20px">
					@foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
					{
						<div>@e.ErrorMessage</div>
					}
				</div>
			}

			<!-- ── Painel Crédito ───────────────────────────────── -->
			<div class="painel @(Model.FormaPagamento == "Crédito" ? "visivel" : "")" id="painel-Crédito">

				<!-- Cartão visual animado -->
				<div class="card-visual">
					<span class="bandeira" id="bandeira">💳</span>
					<div class="card-visual-chip"></div>
					<div class="card-visual-numero" id="previewNumero">•••• •••• •••• ••••</div>
					<div class="card-visual-footer">
						<div>
							<div style="font-size:10px;margin-bottom:2px">Titular</div>
							<div class="card-visual-nome" id="previewNome">NOME DO TITULAR</div>
						</div>
						<div style="text-align:right">
							<div style="font-size:10px;margin-bottom:2px">Validade</div>
							<div class="card-visual-nome" id="previewValidade">MM/AA</div>
						</div>
					</div>
				</div>

				<!-- Campos -->
				<div class="ng-field">
					<label class="ng-label">Número do cartão</label>
					<input class="ng-input" name="NumeroCartao" id="numCartao"
						   placeholder="0000 0000 0000 0000" maxlength="19"
						   value="@Model.NumeroCartao"
						   oninput="mascaraCartao(this)" autocomplete="cc-number" />
				</div>

				<div class="ng-field">
					<label class="ng-label">Nome do titular (como no cartão)</label>
					<input class="ng-input" name="NomeTitular" id="nomeCartao"
						   placeholder="FULANO DA SILVA" maxlength="26"
						   value="@Model.NomeTitular"
						   oninput="document.getElementById('previewNome').textContent = this.value.toUpperCase() || 'NOME DO TITULAR'"
						   style="text-transform:uppercase" autocomplete="cc-name" />
				</div>

				<div class="campo-grid-3">
					<div class="ng-field">
						<label class="ng-label">Validade</label>
						<input class="ng-input" name="Validade" id="validade"
							   placeholder="MM/AA" maxlength="5"
							   value="@Model.Validade"
							   oninput="mascaraValidade(this)" autocomplete="cc-exp" />
					</div>
					<div class="ng-field">
						<label class="ng-label">CVV</label>
						<input class="ng-input" name="Cvv" type="password"
							   placeholder="•••" maxlength="4"
							   value="@Model.Cvv" autocomplete="cc-csc" />
					</div>
					<div class="ng-field">
						<label class="ng-label">Parcelas</label>
						<select class="ng-select" name="Parcelas">
							@for (int i = 1; i <= 12; i++)
							{
								var valor = Model.Total / i;
								<option value="@i" selected="@(Model.Parcelas == i)">
									@i× de R$ @valor.ToString("N2")
								</option>
							}
						</select>
					</div>
				</div>
			</div>

			<!-- ── Painel Débito ────────────────────────────────── -->
			<div class="painel @(Model.FormaPagamento == "Débito" ? "visivel" : "")" id="painel-Débito">

				<div class="card-visual">
					<span class="bandeira" id="bandeira-deb">💳</span>
					<div class="card-visual-chip"></div>
					<div class="card-visual-numero" id="previewNumeroDeb">•••• •••• •••• ••••</div>
					<div class="card-visual-footer">
						<div>
							<div style="font-size:10px;margin-bottom:2px">Titular</div>
							<div class="card-visual-nome" id="previewNomeDeb">NOME DO TITULAR</div>
						</div>
						<div style="text-align:right">
							<div style="font-size:10px;margin-bottom:2px">Validade</div>
							<div class="card-visual-nome" id="previewValidadeDeb">MM/AA</div>
						</div>
					</div>
				</div>

				<div class="ng-field">
					<label class="ng-label">Número do cartão</label>
					<input class="ng-input" name="NumeroCartao" id="numCartaoDeb"
						   placeholder="0000 0000 0000 0000" maxlength="19"
						   value="@Model.NumeroCartao"
						   oninput="mascaraCartaoDeb(this)" autocomplete="cc-number" />
				</div>
				<div class="ng-field">
					<label class="ng-label">Nome do titular</label>
					<input class="ng-input" name="NomeTitular" id="nomeCartaoDeb"
						   placeholder="FULANO DA SILVA" maxlength="26"
						   value="@Model.NomeTitular"
						   oninput="document.getElementById('previewNomeDeb').textContent = this.value.toUpperCase() || 'NOME DO TITULAR'"
						   style="text-transform:uppercase" autocomplete="cc-name" />
				</div>
				<div class="campo-grid-2">
					<div class="ng-field">
						<label class="ng-label">Validade</label>
						<input class="ng-input" name="Validade" id="validadeDeb"
							   placeholder="MM/AA" maxlength="5"
							   value="@Model.Validade"
							   oninput="mascaraValidadeDeb(this)" autocomplete="cc-exp" />
					</div>
					<div class="ng-field">
						<label class="ng-label">CVV</label>
						<input class="ng-input" name="Cvv" type="password"
							   placeholder="•••" maxlength="4"
							   value="@Model.Cvv" autocomplete="cc-csc" />
					</div>
				</div>
			</div>

			<!-- ── Painel Pix ───────────────────────────────────── -->
			<div class="painel @(Model.FormaPagamento == "Pix" ? "visivel" : "")" id="painel-Pix">
				<div class="pix-box">
					<p style="font-size:13px;color:var(--ng-text-muted);margin-bottom:16px">
						Escaneie o QR Code ou copie a chave Pix para pagar.
						O pagamento é confirmado em segundos.
					</p>

					<div class="pix-qr">
						<img src="@Model.PixQrCodeUrl" alt="QR Code Pix"
							 width="180" height="180" />
					</div>

					<p style="font-size:12px;color:var(--ng-text-dim);margin-bottom:4px;text-transform:uppercase;letter-spacing:.06em">
						Chave Pix
					</p>
					<div class="pix-chave-wrap">
						<span class="pix-chave" id="pixChaveTexto">@Model.PixChave</span>
						<button type="button" class="btn-copiar-pix"
								onclick="copiarPix()" title="Copiar chave">
							⧉
						</button>
					</div>

					<div style="margin-top:16px;padding:12px;background:rgba(34,197,94,.07);border:1px solid rgba(34,197,94,.2);border-radius:8px;font-size:12px;color:#4ade80">
						✅ Após o pagamento, clique em <strong>"Confirmar pagamento Pix"</strong> abaixo.
					</div>
				</div>
			</div>

		</div>

		<!-- ── Coluna direita: resumo do pedido ────────────────── -->
		<div>
			<div class="ng-card" style="position:sticky;top:80px">
				<p class="ng-resumo-h">Resumo do pedido</p>

				@foreach (var item in Model.Itens)
				{
					<div class="resumo-item">
						<span style="max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
							@item.Titulo <span class="text-muted">×@item.Quantidade</span>
						</span>
						<span>R$ @item.Subtotal.ToString("N2")</span>
					</div>
				}

				<div class="ng-resumo-total" style="margin-top:14px">
					<span>Total</span>
					<span>R$ @Model.Total.ToString("N2")</span>
				</div>

				<div style="margin-top:20px">
					<button type="submit" id="btnFinalizar"
							class="btn-ng btn-ng-primary btn-ng-full btn-ng-lg">
						Confirmar pagamento
					</button>
				</div>

				<div class="seguranca">
					🔒 Pagamento 100% seguro e criptografado
				</div>

				<div style="text-align:center;margin-top:14px">
					<a asp-action="Index" class="text-muted" style="font-size:12px">← Voltar ao carrinho</a>
				</div>
			</div>
		</div>

	</div>
</form>

@section Scripts {
	<script>
		// ── Selecionar método de pagamento ──────────────────────────
		function selecionarMetodo(metodo, btn) {
			document.getElementById('inputFormaPagamento').value = metodo;

			// Atualiza tabs
			document.querySelectorAll('.metodo-btn').forEach(b => b.classList.remove('ativo'));
			btn.classList.add('ativo');

			// Mostra painel correto
			document.querySelectorAll('.painel').forEach(p => p.classList.remove('visivel'));
			const painel = document.getElementById('painel-' + metodo);
			if (painel) painel.classList.add('visivel');

			// Atualiza label do botão para Pix
			const btnFinal = document.getElementById('btnFinalizar');
			btnFinal.textContent = metodo === 'Pix'
				? 'Confirmar pagamento Pix'
				: 'Confirmar pagamento';
		}

		// ── Máscara número do cartão (Crédito) ──────────────────────
		function mascaraCartao(input) {
			let v = input.value.replace(/\D/g, '').substring(0, 16);
			input.value = v.replace(/(.{4})/g, '$1 ').trim();
			atualizarPreviewCartao(v);
			detectarBandeira(v, 'bandeira');
		}

		function mascaraCartaoDeb(input) {
			let v = input.value.replace(/\D/g, '').substring(0, 16);
			input.value = v.replace(/(.{4})/g, '$1 ').trim();
			atualizarPreviewCartaoDeb(v);
			detectarBandeira(v, 'bandeira-deb');
		}

		function atualizarPreviewCartao(numeros) {
			const pad    = numeros.padEnd(16, '•');
			const grupos = pad.match(/.{1,4}/g) || [];
			document.getElementById('previewNumero').textContent = grupos.join(' ');
		}

		function atualizarPreviewCartaoDeb(numeros) {
			const pad    = numeros.padEnd(16, '•');
			const grupos = pad.match(/.{1,4}/g) || [];
			document.getElementById('previewNumeroDeb').textContent = grupos.join(' ');
		}

		// ── Detectar bandeira pelo prefixo ───────────────────────────
		function detectarBandeira(num, elId) {
			const el  = document.getElementById(elId);
			const n   = num.replace(/\D/g, '');
			let emoji = '💳';
			if      (/^4/.test(n))                          emoji = '🔵'; // Visa
			else if (/^5[1-5]/.test(n) || /^2[2-7]/.test(n)) emoji = '🔴'; // Mastercard
			else if (/^3[47]/.test(n))                      emoji = '🟢'; // Amex
			else if (/^6(?:011|5)/.test(n))                 emoji = '🟠'; // Discover
			else if (/^(?:606282|3841)/.test(n))            emoji = '🟣'; // Hipercard
			else if (/^(?:384100|438935|504175)/.test(n))   emoji = '⚫'; // Elo
			el.textContent = emoji;
		}

		// ── Máscara validade ─────────────────────────────────────────
		function mascaraValidade(input) {
			let v = input.value.replace(/\D/g, '').substring(0, 4);
			if (v.length > 2) v = v.slice(0,2) + '/' + v.slice(2);
			input.value = v;
			document.getElementById('previewValidade').textContent = v || 'MM/AA';
		}

		function mascaraValidadeDeb(input) {
			let v = input.value.replace(/\D/g, '').substring(0, 4);
			if (v.length > 2) v = v.slice(0,2) + '/' + v.slice(2);
			input.value = v;
			document.getElementById('previewValidadeDeb').textContent = v || 'MM/AA';
		}

		// ── Copiar chave Pix ─────────────────────────────────────────
		function copiarPix() {
			const chave = document.getElementById('pixChaveTexto').textContent;
			navigator.clipboard.writeText(chave).then(() => {
				const btn = document.querySelector('.btn-copiar-pix');
				btn.textContent = '✓';
				setTimeout(() => btn.textContent = '⧉', 2000);
			});
		}

		// ── Inicializa com o método que veio do model (repost) ───────
		document.addEventListener('DOMContentLoaded', () => {
			const metodoAtual = document.getElementById('inputFormaPagamento').value;
			if (metodoAtual) {
				const btn = document.querySelector(`.metodo-btn[onclick*="${metodoAtual}"]`);
				if (btn) selecionarMetodo(metodoAtual, btn);
			}
		});
	</script>
}
