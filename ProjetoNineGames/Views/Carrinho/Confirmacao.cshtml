@{
    ViewData["Title"] = "Compra Confirmada";
}

<style>
    .confirmacao-wrap {
        max-width: 520px;
        margin: 60px auto 0;
        text-align: center;
    }

    .check-circle {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background: rgba(34,197,94,.1);
        border: 2px solid rgba(34,197,94,.3);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 36px;
        margin: 0 auto 24px;
        animation: pop .4s cubic-bezier(.34,1.56,.64,1);
    }

    @@keyframes pop {
        from { transform: scale(0); opacity: 0; }
        to   { transform: scale(1); opacity: 1; }
    }

    .confirmacao-titulo {
        font-family: var(--ng-font-display);
        font-size: 2rem;
        font-weight: 800;
        color: var(--ng-text);
        margin-bottom: 10px;
    }

    .confirmacao-sub {
        font-size: 14px;
        color: var(--ng-text-muted);
        line-height: 1.7;
        margin-bottom: 32px;
    }

    .confirmacao-id {
        display: inline-block;
        background: var(--ng-orange-subtle);
        border: 1px solid var(--ng-border-o);
        border-radius: 8px;
        padding: 8px 18px;
        font-family: monospace;
        font-size: 15px;
        color: var(--ng-orange);
        margin-bottom: 32px;
        letter-spacing: 1px;
    }

    .confirmacao-acoes {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }
</style>

<div class="confirmacao-wrap">
    <div class="check-circle">✓</div>

    <h1 class="confirmacao-titulo">Compra Confirmada!</h1>
    <p class="confirmacao-sub">
        Seu pagamento foi processado com sucesso.<br />
        Os jogos já estão disponíveis na sua biblioteca.
    </p>

    @if (ViewBag.IdVenda != null)
    {
        <div class="confirmacao-id">Pedido #@ViewBag.IdVenda</div>
    }

    <div class="confirmacao-acoes">
        <a asp-controller="Biblioteca" asp-action="MinhaBiblioteca"
           class="btn-ng btn-ng-primary btn-ng-lg">
             Ir para minha biblioteca
        </a>
        <a asp-controller="Jogo" asp-action="Index"
           class="btn-ng btn-ng-ghost">
            Continuar comprando
        </a>
    </div>
</div>
