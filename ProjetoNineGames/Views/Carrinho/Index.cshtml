@model List<ProjetoNineGames.Models.ItemCarrinho>
@{
    ViewData["Title"] = "Carrinho";
    var total = Model.Sum(i => i.Subtotal);
}

<h2 style="margin-bottom:20px">🛒 Carrinho</h2>

@if (TempData["ok"]   != null) { <div class="ng-alert ng-alert-ok">@TempData["ok"]</div> }
@if (TempData["erro"] != null) { <div class="ng-alert ng-alert-erro">@TempData["erro"]</div> }

@if (!Model.Any())
{
    <div class="ng-vazio">
        <div class="icon">🛒</div>
        <p>Seu carrinho está vazio.</p>
        <a asp-controller="Jogo" asp-action="Index" class="btn-ng btn-ng-primary">Explorar jogos</a>
    </div>
}
else
{
    <div class="ng-cart-wrap">

        <!-- Itens -->
        <div class="ng-card" style="padding:0;overflow:hidden">
            <table class="ng-cart-table">
                <thead>
                    <tr>
                        <th></th>
                        <th>Jogo</th>
                        <th>Preço</th>
                        <th>Qtd</th>
                        <th>Subtotal</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td style="padding-left:16px">
                                <div class="ng-thumb">
                                    @if (!string.IsNullOrWhiteSpace(item.ImagemUrl))
                                    { <img src="~/@item.ImagemUrl" alt="@item.Titulo" /> }
                                    else { <span>🎮</span> }
                                </div>
                            </td>
                            <td style="font-weight:600">@item.Titulo</td>
                            <td class="text-muted">R$ @item.PrecoUnitario.ToString("N2")</td>
                            <td>
                                <form asp-action="AlterarQtd" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="jogoId" value="@item.JogoId" />
                                    <input class="ng-qty" type="number" name="quantidade"
                                           value="@item.Quantidade" min="1"
                                           onchange="this.form.submit()" />
                                </form>
                            </td>
                            <td style="font-weight:700;color:var(--ng-orange)">
                                R$ @item.Subtotal.ToString("N2")
                            </td>
                            <td style="padding-right:16px">
                                <form asp-action="Remover" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="jogoId" value="@item.JogoId" />
                                    <button class="btn-ng btn-ng-danger btn-ng-sm"
                                            onclick="return confirm('Remover?')">✕</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Resumo -->
        <div class="ng-card">
            <p class="ng-resumo-h">Resumo do pedido</p>

            @foreach (var item in Model)
            {
                <div class="ng-resumo-linha">
                    <span>@item.Titulo × @item.Quantidade</span>
                    <span>R$ @item.Subtotal.ToString("N2")</span>
                </div>
            }

            <div class="ng-resumo-total">
                <span>Total</span>
                <span>R$ @total.ToString("N2")</span>
            </div>

            <div style="margin-top:20px">
                <a asp-action="Checkout" class="btn-ng btn-ng-primary btn-ng-full btn-ng-lg">
                    Ir para pagamento →
                </a>
            </div>

            <div style="text-align:center;margin-top:14px">
                <a asp-controller="Jogo" asp-action="Index"
                   class="text-muted" style="font-size:13px">← Continuar comprando</a>
            </div>
        </div>

    </div>
}
