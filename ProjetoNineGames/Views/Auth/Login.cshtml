@{
    Layout = null;
    ViewData["Title"] = "Entrar — NineGames";
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="ng-auth-page">
        <div class="ng-auth-card">
            <div class="ng-auth-logo">
                <img src="~/images/Nine.png" alt="NineGames" asp-append-version="true" />
            </div>
            <h1 class="ng-auth-title">Entrar</h1>
            <p class="ng-auth-sub">faça o login na sua conta</p>

            @if (ViewBag.Error != null)
            {
                <div class="ng-alert ng-alert-erro">@ViewBag.Error</div>
            }

            <form method="post" asp-action="Login" asp-controller="Auth">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

                <div class="ng-field">
                    <input class="ng-input" type="email" name="email" placeholder="Email" required autofocus />
                </div>
                <div class="ng-field">
                    <input class="ng-input" type="password" name="senha" placeholder="Senha" required />
                </div>

                <button type="submit" class="btn-ng btn-ng-primary btn-ng-full btn-ng-lg">Avançar</button>
            </form>

            <a asp-controller="Usuario" asp-action="Registrar" class="ng-auth-link">
                Novo no site? <strong>Crie sua conta</strong>
            </a>
        </div>
    </div>
</body>
</html>
