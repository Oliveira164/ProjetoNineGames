@model IEnumerable<ProjetoNineGames.Models.Jogo>
@{ ViewData["Title"] = "Gerenciar Jogos"; }

<div class="ng-section-header">
    <h2>Gerenciar Jogos</h2>
    <form class="ng-busca" method="get">
        <input class="ng-input" type="text" name="busca" value="@ViewBag.Busca" placeholder="Buscar..." />
        <button type="submit" class="btn-ng btn-ng-ghost btn-ng-sm">Buscar</button>
    </form>
    <a asp-action="Criar" class="btn-ng btn-ng-primary">+ Novo Jogo</a>
</div>

@if (ViewBag.Ok   != null) { <div class="ng-alert ng-alert-ok">@ViewBag.Ok</div> }
@if (ViewBag.Erro != null) { <div class="ng-alert ng-alert-erro">@ViewBag.Erro</div> }

<div class="ng-card" style="padding:0;overflow:hidden">
    <table class="ng-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Título</th>
                <th>Categoria</th>
                <th>Preço</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var j in Model)
            {
                <tr>
                    <td class="text-muted">@j.Id</td>
                    <td style="font-weight:600">@j.Titulo</td>
                    <td>
                        @if (!string.IsNullOrWhiteSpace(j.Categoria))
                        { <span class="ng-badge ng-badge-orange">@j.Categoria</span> }
                        else { <span class="text-muted">—</span> }
                    </td>
                    <td>
                        @if (j.Preco == 0) { <span class="ng-badge ng-badge-green">Grátis</span> }
                        else               { <span>R$ @j.Preco.ToString("N2")</span> }
                    </td>
                    <td>
                        <div style="display:flex;gap:6px">
                            <a asp-action="Editar" asp-route-id="@j.Id" class="btn-ng btn-ng-ghost btn-ng-sm">Editar</a>
                            <form asp-action="Excluir" method="post"
                                  onsubmit="return confirm('Excluir @Html.Raw(j.Titulo.Replace("'","\\'") ?? "")?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@j.Id" />
                                <button type="submit" class="btn-ng btn-ng-danger btn-ng-sm">Excluir</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" style="text-align:center;padding:40px 0;color:var(--ng-text-dim)">
                        Nenhum jogo cadastrado.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
