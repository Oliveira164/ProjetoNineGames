@model ProjetoNineGames.Models.Jogo
@{ ViewData["Title"] = "Editar Jogo"; }

<h2 style="margin-bottom:20px">Editar Jogo</h2>

<div class="ng-form-card">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="ng-alert ng-alert-erro">
            @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            { <div>@e.ErrorMessage</div> }
        </div>
    }

    <form asp-action="Editar" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="ImagemUrl" />

        <div class="ng-field-grid">

            <div class="ng-field full">
                <label class="ng-label">Título *</label>
                <input class="ng-input" asp-for="Titulo" required />
            </div>

            <div class="ng-field">
                <label class="ng-label">Categoria</label>
                <select class="ng-select" asp-for="Categoria" asp-items="ViewBag.Categorias">
                    <option value="">(Selecione)</option>
                </select>
            </div>

            <div class="ng-field">
                <label class="ng-label">Preço (R$) *</label>
                <input class="ng-input" asp-for="Preco" type="number" step="0.01" min="0.00" required />
            </div>

            <div class="ng-field full">
                <label class="ng-label">Imagem</label>
                @if (!string.IsNullOrWhiteSpace(Model.ImagemUrl))
                {
                    <img src="~/@Model.ImagemUrl" alt="Imagem atual"
                         style="width:80px;height:80px;object-fit:cover;border-radius:8px;border:1px solid var(--ng-border);margin-bottom:8px;" />
                    <span class="ng-hint">Deixe vazio para manter a imagem atual</span>
                }
                <input class="ng-input" type="file" name="imagem" accept="image/jpeg,image/png,image/webp" />
            </div>

            <div class="ng-field full">
                <label class="ng-label">Descrição</label>
                <textarea class="ng-textarea" asp-for="Descricao" rows="4"></textarea>
            </div>

        </div>
        <div class="ng-form-actions">
            <button type="submit" class="btn-ng btn-ng-primary">Salvar alterações</button>
            <a asp-action="Gerenciar" class="btn-ng btn-ng-ghost">Cancelar</a>
        </div>
    </form>
</div>
