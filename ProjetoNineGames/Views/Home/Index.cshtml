@{
    ViewData["Title"] = "Home Page";
}

@section Styles {
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            color: #e8e8ee;
        }

        .home-wrapper {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 0 60px;
            font-family: 'Segoe UI', system-ui, sans-serif;
        }

        .hero {
            position: relative;
            width: 100%;
            height: 440px;
            overflow: hidden;
            border-radius: 0 0 16px 16px;
            margin-bottom: 40px;
        }

        .hero-bg {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center top;
            display: block;
        }

        .hero-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient( to right, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.4) 50%, rgba(0,0,0,0.1) 100% );
        }

        .hero-content {
            position: absolute;
            bottom: 36px;
            left: 36px;
            right: 36px;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
        }

        .hero-title {
            font-size: 13px;
            font-weight: 700;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: #fff;
            opacity: 0.5;
            margin-bottom: 8px;
        }

        .hero-game-title {
            font-size: 42px;
            font-weight: 900;
            color: #fff;
            line-height: 1;
            text-shadow: 0 2px 20px rgba(0,0,0,0.8);
            text-transform: uppercase;
            letter-spacing: -1px;
        }

            .hero-game-title span {
                display: block;
                font-size: 28px;
                letter-spacing: 4px;
                opacity: 0.75;
            }

        .hero-side-cards {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .hero-side-card {
            width: 200px;
            height: 110px;
            border-radius: 8px;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.1);
            cursor: pointer;
            transition: transform 0.2s, border-color 0.2s;
            background: #1a1a1e;
        }

            .hero-side-card:hover {
                transform: scale(1.03);
                border-color: rgba(255,255,255,0.3);
            }

            .hero-side-card img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .hero-dots {
            position: absolute;
            bottom: 14px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 6px;
        }

        .hero-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: rgba(255,255,255,0.3);
            border: none;
            cursor: pointer;
            padding: 0;
            transition: background 0.2s;
        }

            .hero-dot.active {
                background: #fff;
            }

        .section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 18px;
            padding: 0 4px;
        }

        .section-title {
            font-size: 22px;
            font-weight: 800;
            color: #ffffff;
            letter-spacing: -0.3px;
        }

        .btn-ver-mais {
            background: transparent;
            border: 1px solid #3f3f46;
            color: #a1a1aa;
            padding: 6px 16px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            display: inline-block;
        }

            .btn-ver-mais:hover {
                border-color: #f97316;
                color: #f97316;
                background: rgba(249,115,22,0.06);
            }

        .section {
            margin-bottom: 44px;
            padding: 0 8px;
        }

        .grid-em-alta {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
        }

            .grid-em-alta .card-game:first-child {
                grid-column: span 2;
                grid-row: span 2;
            }

                .grid-em-alta .card-game:first-child .card-game-inner {
                    height: 280px;
                }

        .grid-lancamentos {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
        }

            .grid-lancamentos .card-game:first-child {
                grid-column: span 1;
                grid-row: span 2;
            }

                .grid-lancamentos .card-game:first-child .card-game-inner {
                    height: 280px;
                }

        .grid-em-breve {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
        }

            .grid-em-breve .card-game-inner {
                height: 180px;
            }

            .grid-em-breve .card-game:first-child {
                grid-column: span 1;
            }

        .grid-free {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
        }

            .grid-free .card-game:nth-child(3) {
                grid-column: span 1;
            }

            .grid-free .card-game:nth-child(4) {
                grid-column: span 1;
                grid-row: 2;
            }

            .grid-free .card-game:nth-child(5) {
                grid-column: 2;
                grid-row: 2;
            }

            .grid-free .card-game:nth-child(6) {
                grid-column: 3;
                grid-row: 2;
            }

        .card-game {
            cursor: pointer;
        }

        .card-game-inner {
            height: 130px;
            border-radius: 10px;
            overflow: hidden;
            position: relative;
            background: #1a1a1e;
            border: 1px solid #1f1f23;
            transition: transform 0.22s cubic-bezier(0.34,1.56,0.64,1), border-color 0.2s, box-shadow 0.2s;
        }

        .card-game:hover .card-game-inner {
            transform: translateY(-4px) scale(1.02);
            border-color: rgba(249,115,22,0.35);
            box-shadow: 0 12px 32px rgba(0,0,0,0.6), 0 0 0 1px rgba(249,115,22,0.15);
        }

        .card-game-inner img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform 0.3s;
        }

        .card-game:hover .card-game-inner img {
            transform: scale(1.05);
        }

        .card-game-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 50%);
            opacity: 0;
            transition: opacity 0.2s;
            display: flex;
            align-items: flex-end;
            padding: 10px 12px;
        }

        .card-game:hover .card-game-overlay {
            opacity: 1;
        }

        .card-game-name {
            font-size: 11px;
            font-weight: 700;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .card-placeholder {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: 600;
            color: rgba(255,255,255,0.5);
            text-align: center;
            padding: 12px;
            background: linear-gradient(135deg, #1a1a1e 0%, #27272a 100%);
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        .genre-section {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
            margin-bottom: 44px;
            padding: 0 8px;
        }

        .genre-column h3 {
            font-size: 16px;
            font-weight: 700;
            color: #fff;
            margin-bottom: 12px;
            padding-bottom: 8px;
            border-bottom: 1px solid #27272a;
        }

        .genre-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 8px 0;
            border-bottom: 1px solid #18181b;
            cursor: pointer;
            text-decoration: none;
            transition: background 0.15s;
            border-radius: 6px;
            padding: 8px 6px;
        }

            .genre-item:hover {
                background: #18181b;
            }

        .genre-item-thumb {
            width: 52px;
            height: 52px;
            border-radius: 6px;
            overflow: hidden;
            flex-shrink: 0;
            background: #27272a;
        }

            .genre-item-thumb img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .genre-item-thumb-placeholder {
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #27272a, #3f3f46);
        }

        .genre-item-info {
            flex: 1;
            min-width: 0;
        }

        .genre-item-name {
            font-size: 13px;
            font-weight: 600;
            color: #e4e4e7;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            margin-bottom: 2px;
        }

        .genre-item-price {
            font-size: 12px;
            color: #f97316;
            font-weight: 700;
        }

            .genre-item-price.free {
                color: #22c55e;
            }

        .home-footer {
            background: #111113;
            border-top: 1px solid #1f1f23;
            padding: 36px 8px 24px;
            margin-top: 20px;
        }

        .footer-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 28px;
        }

        .footer-brand {
            font-size: 20px;
            font-weight: 900;
            color: #f97316;
            letter-spacing: -0.5px;
        }

        .footer-socials {
            display: flex;
            gap: 14px;
        }

            .footer-socials a {
                width: 36px;
                height: 36px;
                border-radius: 50%;
                background: #27272a;
                display: flex;
                align-items: center;
                justify-content: center;
                color: #a1a1aa;
                text-decoration: none;
                font-size: 15px;
                transition: background 0.2s, color 0.2s;
            }

                .footer-socials a:hover {
                    background: #f97316;
                    color: #fff;
                }

        .footer-cols {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 28px;
        }

        .footer-col h4 {
            font-size: 11px;
            font-weight: 700;
            color: #fff;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            margin-bottom: 12px;
        }

        .footer-col ul {
            list-style: none;
        }

            .footer-col ul li {
                margin-bottom: 6px;
            }

                .footer-col ul li a {
                    font-size: 12px;
                    color: #71717a;
                    text-decoration: none;
                    transition: color 0.2s;
                }

                    .footer-col ul li a:hover {
                        color: #f97316;
                    }

        .footer-copy {
            border-top: 1px solid #1f1f23;
            padding-top: 18px;
            text-align: center;
            font-size: 11px;
            color: #52525b;
            line-height: 1.6;
        }

        @@media (max-width: 900px) {
            .grid-em-alta {
                grid-template-columns: repeat(2, 1fr);
            }

            .grid-lancamentos {
                grid-template-columns: repeat(2, 1fr);
            }

            .genre-section {
                grid-template-columns: 1fr;
            }

            .footer-cols {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @@media (max-width: 600px) {
            .hero {
                height: 260px;
            }

            .hero-side-cards {
                display: none;
            }

            .hero-game-title {
                font-size: 28px;
            }

            .grid-em-alta, .grid-lancamentos, .grid-free, .grid-em-breve {
                grid-template-columns: repeat(2, 1fr);
            }

                .grid-em-alta .card-game:first-child, .grid-lancamentos .card-game:first-child {
                    grid-column: span 2;
                }

            .footer-cols {
                grid-template-columns: 1fr 1fr;
            }
        }
    </style>
}

<div class="home-wrapper">

    <div class="hero">
        <img class="hero-bg" src="/images/fundo-tela-home-cod.png" alt="Call of Duty Warzone" onerror="this.style.background='linear-gradient(135deg,#1a0a00,#0a0a0c)';this.style.height='100%';this.removeAttribute('src')" />
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <div class="hero-text">
                <p class="hero-title">Destaque</p>
                <h2 class="hero-game-title">
                    <span>Call of Duty</span>
                    WARZONE
                </h2>
            </div>
            <div class="hero-side-cards">
                <div class="hero-side-card">
                    <div class="card-placeholder">Rise of the Ronin</div>
                </div>
                <div class="hero-side-card">
                    <div class="card-placeholder">Em Destaque</div>
                </div>
            </div>
        </div>
        <div class="hero-dots">
            <button class="hero-dot active"></button>
            <button class="hero-dot"></button>
            <button class="hero-dot"></button>
        </div>
    </div>

    <section class="section">
        <div class="section-header">
            <h2 class="section-title">Em alta</h2>
            <a asp-controller="Jogo" asp-action="Index" class="btn-ver-mais">Ver Mais</a>
        </div>
        <div class="grid-em-alta">
            <div class="card-game">
                <div class="card-game-inner">
                    <div class="card-placeholder" style="background-color:#7CC5F4"><img src="~/images/fortnite-capa-atualizado.jpg" /></div>
                    <div class="card-game-overlay"><a asp-action="Detalhe" asp-controller="Jogo" asp-route-id="5" class="card-game-name">Fortnite</a></div>
                </div>
            </div>
            <div class="card-game">
                <div class="card-game-inner">
                    <div class="card-placeholder" style="background-color:#7CC5F4"><img src="~/images/fc26.jpg" /></div>
                    <div class="card-game-overlay"><span class="card-game-name">EA Sports FC 26</span></div>
                </div>
            </div>
            <div class="card-game">
                <div class="card-game-inner">
                    <div class="card-placeholder" style="background:linear-gradient(135deg,#1a1a3a,#2a1a5e)">Rocket League</div>
                    <div class="card-game-overlay"><span class="card-game-name">Rocket League</span></div>
                </div>
            </div>
            <div class="card-game">
                <div class="card-game-inner">
                    <div class="card-placeholder" style="background:linear-gradient(135deg,#2a1a0a,#1a0a0a)">Hollow Knight</div>
                    <div class="card-game-overlay"><span class="card-game-name">Hollow Knight</span></div>
                </div>
            </div>
            <div class="card-game">
                <div class="card-game-inner">
                    <div class="card-placeholder" style="background:linear-gradient(135deg,#3a1a0a,#5e2a0e)">Far Cry 6</div>
                    <div class="card-game-overlay"><span class="card-game-name">Far Cry 6</span></div>
                </div>
            </div>
            <div class="card-game">
                <div class="card-game-inner">
                    <div class="card-placeholder" style="background:linear-gradient(135deg,#3a0a0a,#5e0e0e)">Red Dead II</div>
                    <div class="card-game-overlay"><span class="card-game-name">Red Dead Redemption 2</span></div>
                </div>
            </div>
            <div class="card-game">
                <div class="card-game-inner">
                    <div class="card-placeholder" style="background:linear-gradient(135deg,#2a1a0a,#4a2a0a)">Elden Ring</div>
                    <div class="card-game-overlay"><span class="card-game-name">Elden Ring</span></div>
                </div>
            </div>
        </div>
    </section>

    <section class="section">
        <div class="section-header">
            <h2 class="section-title">Lançamentos</h2>
            <a asp-controller="Jogo" asp-action="Index" class="btn-ver-mais">Ver Mais</a>
        </div>
        <div class="grid-lancamentos">
            <div class="card-game">
                <div class="card-game-inner">
                    <div class="card-placeholder" style="background:linear-gradient(135deg,#0a1a2a,#0a2a1a);font-size:18px;font-weight:900;color:#60a5fa">WINDROSE</div>
                    <div class="card-game-overlay"><span class="card-game-name">Windrose</span></div>
                </div>
            </div>
            <div class="card-game">
                <div class="card-game-inner">
                    <div class="card-placeholder" style="background:linear-gradient(135deg,#2a1a0a,#3a0a0a)">Far Far West</div>
                    <div class="card-game-overlay"><span class="card-game-name">Far Far West</span></div>
                </div>
            </div>
            <div class="card-game">
                <div class="card-game-inner">
                    <div class="card-placeholder" style="background:linear-gradient(135deg,#0a0a2a,#1a0a3a)">Freedom Wars</div>
                    <div class="card-game-overlay"><span class="card-game-name">Freedom Wars</span></div>
                </div>
            </div>
            <div class="card-game">
                <div class="card-game-inner">
                    <div class="card-placeholder" style="background:linear-gradient(135deg,#1a0a0a,#2a1a0a)">Marvel Cosmic</div>
                    <div class="card-game-overlay"><span class="card-game-name">Marvel Cosmic Invasion</span></div>
                </div>
            </div>
            <div class="card-game">
                <div class="card-game-inner">
                    <div class="card-placeholder" style="background:linear-gradient(135deg,#1a1a0a,#2a2a0a)">Crimson Desert</div>
                    <div class="card-game-overlay"><span class="card-game-name">Crimson Desert</span></div>
                </div>
            </div>
            <div class="card-game">
                <div class="card-game-inner">
                    <div class="card-placeholder" style="background:linear-gradient(135deg,#0a1a0a,#1a3a0a)">Invincible</div>
                    <div class="card-game-overlay"><span class="card-game-name">Invincible</span></div>
                </div>
            </div>
        </div>
    </section>

    <section class="section">
        <div class="section-header">
            <h2 class="section-title">Em breve</h2>
            <a asp-controller="Jogo" asp-action="Index" class="btn-ver-mais">Ver Mais</a>
        </div>
        <div class="grid-em-breve">
            <div class="card-game">
                <div class="card-game-inner">
                    <div class="card-placeholder" style="background:linear-gradient(135deg,#1a0a0a,#2a0a0a);font-size:16px;font-weight:900;letter-spacing:2px">RESIDENT EVIL<br><small style="font-size:10px;opacity:0.6">REQUIEM</small></div>
                    <div class="card-game-overlay"><span class="card-game-name">Resident Evil: Requiem</span></div>
                </div>
            </div>
            <div class="card-game">
                <div class="card-game-inner">
                    <div class="card-placeholder" style="background:linear-gradient(135deg,#0a0a1a,#1a0a0a)">Gears E-Day</div>
                    <div class="card-game-overlay"><span class="card-game-name">Gears of War: E-Day</span></div>
                </div>
            </div>
            <div class="card-game">
                <div class="card-game-inner">
                    <div class="card-placeholder" style="background:linear-gradient(135deg,#0a0a2a,#1a1a3a)">Forza Motorsport 9</div>
                    <div class="card-game-overlay"><span class="card-game-name">Forza Motorsport 9</span></div>
                </div>
            </div>
            <div class="card-game">
                <div class="card-game-inner">
                    <div class="card-placeholder" style="background:linear-gradient(135deg,#1a0a2a,#2a1a3a)">GTA VI</div>
                    <div class="card-game-overlay"><span class="card-game-name">GTA VI</span></div>
                </div>
            </div>
        </div>
    </section>

    <section class="section">
        <div class="section-header">
            <h2 class="section-title">Melhores Jogos gratis</h2>
        </div>
        <div class="grid-free">
            <div class="card-game">
                <div class="card-game-inner">
                    <div class="card-placeholder" style="background:linear-gradient(135deg,#1a2a3a,#2a3a4a);font-weight:900;font-size:16px;color:#60a5fa">The Sims 4</div>
                    <div class="card-game-overlay"><span class="card-game-name">The Sims 4</span></div>
                </div>
            </div>
            <div class="card-game">
                <div class="card-game-inner">
                    <div class="card-placeholder" style="background:linear-gradient(135deg,#2a1a3a,#3a2a4a)">Fall Guys</div>
                    <div class="card-game-overlay"><span class="card-game-name">Fall Guys</span></div>
                </div>
            </div>
            <div class="card-game">
                <div class="card-game-inner">
                    <div class="card-placeholder" style="background:linear-gradient(135deg,#3a1a0a,#4a2a0a)">Pôr do Sol em Eridu</div>
                    <div class="card-game-overlay"><span class="card-game-name">Pôr do Sol em Eridu</span></div>
                </div>
            </div>
            <div class="card-game">
                <div class="card-game-inner">
                    <div class="card-placeholder" style="background:linear-gradient(135deg,#0a1a0a,#1a2a0a)">Rennsport</div>
                    <div class="card-game-overlay"><span class="card-game-name">Rennsport</span></div>
                </div>
            </div>
            <div class="card-game">
                <div class="card-game-inner">
                    <div class="card-placeholder" style="background:linear-gradient(135deg,#0a0a2a,#1a0a3a)">Poppy Playtime</div>
                    <div class="card-game-overlay"><span class="card-game-name">Poppy Playtime</span></div>
                </div>
            </div>
            <div class="card-game">
                <div class="card-game-inner">
                    <div class="card-placeholder" style="background:linear-gradient(135deg,#1a0a0a,#2a0a0a)">Apex Legends</div>
                    <div class="card-game-overlay"><span class="card-game-name">Apex Legends</span></div>
                </div>
            </div>
        </div>
    </section>

    <div class="genre-section">
        <div class="genre-column">
            <h3>Ação/Aventura</h3>
            <a class="genre-item" asp-controller="Jogo" asp-action="Index">
                <div class="genre-item-thumb"><div class="genre-item-thumb-placeholder"></div></div>
                <div class="genre-item-info">
                    <div class="genre-item-name">God of War Ragnarök</div>
                    <div class="genre-item-price">R$249,99</div>
                </div>
            </a>
            <a class="genre-item" asp-controller="Jogo" asp-action="Index">
                <div class="genre-item-thumb"><div class="genre-item-thumb-placeholder"></div></div>
                <div class="genre-item-info">
                    <div class="genre-item-name">Red Dead Redemption 2</div>
                    <div class="genre-item-price">R$279,99</div>
                </div>
            </a>
            <a class="genre-item" asp-controller="Jogo" asp-action="Index">
                <div class="genre-item-thumb"><div class="genre-item-thumb-placeholder"></div></div>
                <div class="genre-item-info">
                    <div class="genre-item-name">The Last of Us</div>
                    <div class="genre-item-price">R$249,99</div>
                </div>
            </a>
            <a class="genre-item" asp-controller="Jogo" asp-action="Index">
                <div class="genre-item-thumb"><div class="genre-item-thumb-placeholder"></div></div>
                <div class="genre-item-info">
                    <div class="genre-item-name">Ghost of Tsushima</div>
                    <div class="genre-item-price">R$249,99</div>
                </div>
            </a>
