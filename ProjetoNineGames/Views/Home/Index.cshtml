@model List<ProjetoNineGames.Models.Jogo>
@{
    ViewData["Title"] = "Home Page";

    var jogos = Model ?? new List<ProjetoNineGames.Models.Jogo>();

    // 🌟 MÁGICA AQUI: Função que busca os jogos exatamente na ordem dos IDs que você passar!
    List<ProjetoNineGames.Models.Jogo> ObterNaOrdem(params int[] ids)
    {
        return ids.Select(id => jogos.FirstOrDefault(j => j.Id == id))
                  .Where(j => j != null) // Ignora se o jogo não for encontrado (evita erros)
                  .ToList()!;
    }

    // LISTAS DE CONFIGURAÇÃO (Altere os IDs aqui quando quiser mudar a vitrine)
    var heroGames = ObterNaOrdem(17, 9, 21);
    var destaqueHero = heroGames.FirstOrDefault();
    var secundariosHero = heroGames.Skip(1).ToList();

    var emAlta = ObterNaOrdem(34, 21, 22, 29, 8, 5, 13);
    var lancamentos = ObterNaOrdem(30, 31, 20, 39, 15, 40); // 39=Marvel Cosmic, 40=Invincible
    var emBreve = ObterNaOrdem(32, 19, 23, 2); // Usei ID 2 (GTA V) pois o VI não está no banco
    var gratis = ObterNaOrdem(37, 35, 36, 24, 33, 18);

    var acaoAventura = ObterNaOrdem(4, 5, 6, 7);
    var rpgs = ObterNaOrdem(10, 11, 12, 28);
    var historia = ObterNaOrdem(25, 26, 27, 14);
}

@section Styles {
    <style>
        .container {
            padding: 0 !important;
            max-width: 100% !important;
        }

        body, html {
            overflow-x: hidden;
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        .home-wrapper {
            width: 100%;
            font-family: 'Segoe UI', system-ui, sans-serif;
            color: #e8e8ee;
        }

        .hero {
            position: relative;
            width: 100%;
            height: 440px;
            overflow: hidden;
            margin-bottom: 40px;
        }

        .hero-bg {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center top;
            display: block;
        }

        .hero-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient( to right, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.4) 50%, rgba(0,0,0,0.1) 100% );
        }

        .hero-content {
            position: absolute;
            bottom: 36px;
            left: 36px;
            right: 36px;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
        }

        .hero-title {
            font-size: 13px;
            font-weight: 700;
            letter-spacing: 3px;
            text-transform: uppercase;
            color: #fff;
            opacity: 0.5;
            margin-bottom: 8px;
        }

        .hero-game-title {
            font-size: 42px;
            font-weight: 900;
            color: #fff;
            line-height: 1;
            text-shadow: 0 2px 20px rgba(0,0,0,0.8);
            text-transform: uppercase;
            letter-spacing: -1px;
        }

            .hero-game-title span {
                display: block;
                font-size: 28px;
                letter-spacing: 4px;
                opacity: 0.75;
            }

        .hero-side-cards {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .hero-side-card {
            width: 200px;
            height: 110px;
            border-radius: 8px;
            overflow: hidden;
            border: 1px solid rgba(255,255,255,0.1);
            cursor: pointer;
            transition: transform 0.2s, border-color 0.2s;
            background: #1a1a1e;
        }

            .hero-side-card:hover {
                transform: scale(1.03);
                border-color: rgba(255,255,255,0.3);
            }

            .hero-side-card img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                display: block;
            }

        .inner {
            padding: 0 24px;
        }

        .section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 18px;
        }

        .section-title {
            font-size: 22px;
            font-weight: 800;
            color: #ffffff;
            letter-spacing: -0.3px;
        }

        .btn-ver-mais {
            background: transparent;
            border: 1px solid #3f3f46;
            color: #a1a1aa;
            padding: 6px 16px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            display: inline-block;
        }

            .btn-ver-mais:hover {
                border-color: #F96300;
                color: #F96300;
                background: rgba(249,99,0,0.06);
            }

        .section {
            margin-bottom: 44px;
        }

        .card-game {
            cursor: pointer;
            display: block;
            text-decoration: none;
        }

        .card-game-inner {
            height: 130px;
            border-radius: 10px;
            overflow: hidden;
            position: relative;
            background: #1a1a1e;
            border: 1px solid #1f1f23;
            transition: transform 0.22s cubic-bezier(0.34,1.56,0.64,1), border-color 0.2s, box-shadow 0.2s;
        }

        .card-game:hover .card-game-inner {
            transform: translateY(-4px) scale(1.02);
            border-color: rgba(249,99,0,0.35);
            box-shadow: 0 12px 32px rgba(0,0,0,0.6), 0 0 0 1px rgba(249,99,0,0.15);
        }

        .card-game-inner img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform 0.3s;
        }

        .card-game:hover .card-game-inner img {
            transform: scale(1.05);
        }

        .card-game-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 50%);
            opacity: 0;
            transition: opacity 0.2s;
            display: flex;
            align-items: flex-end;
            padding: 10px 12px;
        }

        .card-game:hover .card-game-overlay {
            opacity: 1;
        }

        .card-game-name {
            font-size: 11px;
            font-weight: 700;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            text-decoration: none;
        }

        .card-placeholder {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: 600;
            color: rgba(255,255,255,0.5);
            text-align: center;
            padding: 12px;
            background: linear-gradient(135deg, #1a1a1e 0%, #27272a 100%);
            letter-spacing: 0.5px;
            text-transform: uppercase;
        }

        .grid-em-alta {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
        }

            .grid-em-alta .card-game:first-child {
                grid-column: span 2;
                grid-row: span 2;
            }

                .grid-em-alta .card-game:first-child .card-game-inner {
                    height: 280px;
                }

        .grid-lancamentos {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
        }

            .grid-lancamentos .card-game:first-child {
                grid-column: span 1;
                grid-row: span 2;
            }

                .grid-lancamentos .card-game:first-child .card-game-inner {
                    height: 280px;
                }

        .grid-em-breve {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
        }

            .grid-em-breve .card-game-inner {
                height: 180px;
            }

        .grid-free {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 10px;
        }

        .genre-section {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 24px;
            margin-bottom: 0;
            padding: 0 24px 44px;
        }

        .genre-column h3 {
            font-size: 16px;
            font-weight: 700;
            color: #fff;
            margin-bottom: 12px;
            padding-bottom: 8px;
            border-bottom: 1px solid #27272a;
        }

        .genre-item {
            display: flex;
            align-items: center;
            gap: 12px;
            cursor: pointer;
            text-decoration: none;
            transition: background 0.15s;
            border-radius: 6px;
            padding: 8px 6px;
        }

            .genre-item:hover {
                background: #18181b;
            }

        .genre-item-thumb {
            width: 52px;
            height: 52px;
            border-radius: 6px;
            overflow: hidden;
            flex-shrink: 0;
            background: #27272a;
        }

            .genre-item-thumb img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                display: block;
            }

        .genre-item-thumb-placeholder {
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #27272a, #3f3f46);
        }

        .genre-item-info {
            flex: 1;
            min-width: 0;
        }

        .genre-item-name {
            font-size: 13px;
            font-weight: 600;
            color: #e4e4e7;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            margin-bottom: 2px;
        }

        .genre-item-price {
            font-size: 12px;
            color: #F96300;
            font-weight: 700;
        }

            .genre-item-price.free {
                color: #22c55e;
            }

        @@media (max-width: 900px) {
            .grid-em-alta {
                grid-template-columns: repeat(2, 1fr);
            }

            .grid-lancamentos {
                grid-template-columns: repeat(2, 1fr);
            }

            .genre-section {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 600px) {
            .hero {
                height: 260px;
            }

            .hero-side-cards {
                display: none;
            }

            .hero-game-title {
                font-size: 28px;
            }

            .grid-em-alta, .grid-lancamentos, .grid-free, .grid-em-breve {
                grid-template-columns: repeat(2, 1fr);
            }

                .grid-em-alta .card-game:first-child, .grid-lancamentos .card-game:first-child {
                    grid-column: span 2;
                }
        }
    </style>
}

<div class="home-wrapper">

    @if (destaqueHero != null)
    {
        <div class="hero">
            <img class="hero-bg" src="/images/fundo-tela-home-cod.png" alt="Call of Duty Warzone" />
            <div class="hero-overlay"></div>
            <div class="hero-content">
                <a asp-action="Detalhe" asp-controller="Jogo" asp-route-id="@destaqueHero.Id" class="card-game-name" style="text-decoration: none;">
                    <div class="hero-text">
                        <p class="hero-title">Destaque</p>
                        <h2 class="hero-game-title">
                            <span>@destaqueHero.Titulo.Split(' ').FirstOrDefault()</span>
                            @string.Join(" ", destaqueHero.Titulo.Split(' ').Skip(1))
                        </h2>
                    </div>
                </a>
                <div class="hero-side-cards">
                    @foreach (var sec in secundariosHero)
                    {
                        <div class="hero-side-card">
                            <a asp-action="Detalhe" asp-controller="Jogo" asp-route-id="@sec.Id" style="display:block; height:100%;">
                                @if (!string.IsNullOrEmpty(sec.ImagemUrl))
                                {
                                    <img src="~/@sec.ImagemUrl" alt="@sec.Titulo" />
                                }
                                else
                                {
                                    <div class="card-placeholder">@sec.Titulo</div>
                                }
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @if (emAlta.Any())
    {
        <section class="section inner">
            <div class="section-header">
                <h2 class="section-title">Em alta</h2>
                <a asp-controller="Jogo" asp-action="Index" class="btn-ver-mais">Ver Mais</a>
            </div>
            <div class="grid-em-alta">
                @foreach (var j in emAlta)
                {
                    <a asp-action="Detalhe" asp-controller="Jogo" asp-route-id="@j.Id" class="card-game">
                        <div class="card-game-inner">
                            @if (!string.IsNullOrEmpty(j.ImagemUrl))
                            {
                                <img src="~/@j.ImagemUrl" alt="@j.Titulo" />
                            }
                            else
                            {
                                <div class="card-placeholder">@j.Titulo</div>
                            }
                            <div class="card-game-overlay"><span class="card-game-name">@j.Titulo</span></div>
                        </div>
                    </a>
                }
            </div>
        </section>
    }

    @if (lancamentos.Any())
    {
        <section class="section inner">
            <div class="section-header">
                <h2 class="section-title">Lançamentos</h2>
                <a asp-controller="Jogo" asp-action="Index" class="btn-ver-mais">Ver Mais</a>
            </div>
            <div class="grid-lancamentos">
                @foreach (var j in lancamentos)
                {
                    <a asp-action="Detalhe" asp-controller="Jogo" asp-route-id="@j.Id" class="card-game">
                        <div class="card-game-inner">
                            @if (!string.IsNullOrEmpty(j.ImagemUrl))
                            {
                                <img src="~/@j.ImagemUrl" alt="@j.Titulo" />
                            }
                            else
                            {
                                <div class="card-placeholder">@j.Titulo</div>
                            }
                            <div class="card-game-overlay"><span class="card-game-name">@j.Titulo</span></div>
                        </div>
                    </a>
                }
            </div>
        </section>
    }

    @if (emBreve.Any())
    {
        <section class="section inner">
            <div class="section-header">
                <h2 class="section-title">Em breve</h2>
                <a asp-controller="Jogo" asp-action="Index" class="btn-ver-mais">Ver Mais</a>
            </div>
            <div class="grid-em-breve">
                @foreach (var j in emBreve)
                {
                    <a asp-action="Detalhe" asp-controller="Jogo" asp-route-id="@j.Id" class="card-game">
                        <div class="card-game-inner">
                            @if (!string.IsNullOrEmpty(j.ImagemUrl))
                            {
                                <img src="~/@j.ImagemUrl" alt="@j.Titulo" />
                            }
                            else
                            {
                                <div class="card-placeholder">@j.Titulo</div>
                            }
                            <div class="card-game-overlay"><span class="card-game-name">@j.Titulo</span></div>
                        </div>
                    </a>
                }
            </div>
        </section>
    }

    @if (gratis.Any())
    {
        <section class="section inner">
            <div class="section-header">
                <h2 class="section-title">Melhores Jogos Grátis</h2>
            </div>
            <div class="grid-free">
                @foreach (var j in gratis)
                {
                    <a asp-action="Detalhe" asp-controller="Jogo" asp-route-id="@j.Id" class="card-game">
                        <div class="card-game-inner">
                            @if (!string.IsNullOrEmpty(j.ImagemUrl))
                            {
                                <img src="~/@j.ImagemUrl" alt="@j.Titulo" />
                            }
                            else
                            {
                                <div class="card-placeholder">@j.Titulo</div>
                            }
                            <div class="card-game-overlay"><span class="card-game-name">@j.Titulo</span></div>
                        </div>
                    </a>
                }
            </div>
        </section>
    }

    <div class="genre-section">

        <div class="genre-column">
            <h3>Ação / Aventura</h3>
            @foreach (var j in acaoAventura)
            {
                <a class="genre-item" asp-controller="Jogo" asp-action="Detalhe" asp-route-id="@j.Id">
                    <div class="genre-item-thumb">
                        @if (!string.IsNullOrEmpty(j.ImagemUrl))
                        {
                            <img src="~/@j.ImagemUrl" alt="@j.Titulo" />
                        }
                        else
                        {
                            <div class="genre-item-thumb-placeholder"></div>
                        }
                    </div>
                    <div class="genre-item-info">
                        <div class="genre-item-name">@j.Titulo</div>
                        @if (j.Preco == 0)
                        {
                            <div class="genre-item-price free">Gratuito</div>
                        }
                        else
                        {
                            <div class="genre-item-price">R$ @j.Preco.ToString("N2")</div>
                        }
                    </div>
                </a>
            }
        </div>

        <div class="genre-column">
            <h3>RPGs</h3>
            @foreach (var j in rpgs)
            {
                <a class="genre-item" asp-controller="Jogo" asp-action="Detalhe" asp-route-id="@j.Id">
                    <div class="genre-item-thumb">
                        @if (!string.IsNullOrEmpty(j.ImagemUrl))
                        {
                            <img src="~/@j.ImagemUrl" alt="@j.Titulo" />
                        }
                        else
                        {
                            <div class="genre-item-thumb-placeholder"></div>
                        }
                    </div>
                    <div class="genre-item-info">
                        <div class="genre-item-name">@j.Titulo</div>
                        @if (j.Preco == 0)
                        {
                            <div class="genre-item-price free">Gratuito</div>
                        }
                        else
                        {
                            <div class="genre-item-price">R$ @j.Preco.ToString("N2")</div>
                        }
                    </div>
                </a>
            }
        </div>

        <div class="genre-column">
            <h3>História</h3>
            @foreach (var j in historia)
            {
                <a class="genre-item" asp-controller="Jogo" asp-action="Detalhe" asp-route-id="@j.Id">
                    <div class="genre-item-thumb">
                        @if (!string.IsNullOrEmpty(j.ImagemUrl))
                        {
                            <img src="~/@j.ImagemUrl" alt="@j.Titulo" />
                        }
                        else
                        {
                            <div class="genre-item-thumb-placeholder"></div>
                        }
                    </div>
                    <div class="genre-item-info">
                        <div class="genre-item-name">@j.Titulo</div>
                        @if (j.Preco == 0)
                        {
                            <div class="genre-item-price free">Gratuito</div>
                        }
                        else
                        {
                            <div class="genre-item-price">R$ @j.Preco.ToString("N2")</div>
                        }
                    </div>
                </a>
            }
        </div>

    </div>

</div>