@model ProjetoNineGames.Models.Categoria
@{ ViewData["Title"] = "Editar Categoria"; }

<h2 style="margin-bottom:20px">Editar Categoria</h2>

<div class="ng-form-card">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="ng-alert ng-alert-erro">
            @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            { <div>@e.ErrorMessage</div> }
        </div>
    }

    <form asp-action="Editar" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="ng-field">
            <label class="ng-label">Nome *</label>
            <input class="ng-input" asp-for="Nome" required />
        </div>
        <div class="ng-field">
            <label class="ng-label">Descrição</label>
            <textarea class="ng-textarea" asp-for="Descricao" rows="3"></textarea>
        </div>

        <div class="ng-form-actions">
            <button type="submit" class="btn-ng btn-ng-primary">Salvar alterações</button>
            <a asp-action="Index" class="btn-ng btn-ng-ghost">Cancelar</a>
        </div>
    </form>
</div>
