@model IEnumerable<ProjetoNineGames.Models.Categoria>
@{ ViewData["Title"] = "Categorias"; }

<div class="ng-section-header">
    <h2>Categorias</h2>
    <a asp-action="Criar" class="btn-ng btn-ng-primary">+ Nova Categoria</a>
</div>

@if (TempData["ok"]   != null) { <div class="ng-alert ng-alert-ok">@TempData["ok"]</div> }
@if (TempData["erro"] != null) { <div class="ng-alert ng-alert-erro">@TempData["erro"]</div> }

<div class="ng-card" style="padding:0;overflow:hidden">
    <table class="ng-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Nome</th>
                <th>Descrição</th>
                <th>Criado em</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr>
                    <td class="text-muted">@c.Id</td>
                    <td style="font-weight:600">@c.Nome</td>
                    <td class="text-muted">@(c.Descricao ?? "—")</td>
                    <td class="text-muted" style="font-size:12px">@c.CriadoEm.ToString("dd/MM/yyyy")</td>
                    <td>
                        <div style="display:flex;gap:6px">
                            <a asp-action="Editar" asp-route-id="@c.Id" class="btn-ng btn-ng-ghost btn-ng-sm">Editar</a>
                            <form asp-action="Excluir" method="post"
                                  onsubmit="return confirm('Excluir categoria @c.Nome?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@c.Id" />
                                <button type="submit" class="btn-ng btn-ng-danger btn-ng-sm">Excluir</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" style="text-align:center;padding:40px 0;color:var(--ng-text-dim)">
                        Nenhuma categoria cadastrada.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
